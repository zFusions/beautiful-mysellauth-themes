<section class="hero alignment-{{ properties.alignment }} height-{{ properties.height }} component nexus-hero vl-hero" data-component-id="{{ componentId }}">
  <div class="container vl-hero-container">
    <div class="vl-hero-copy" data-reveal-group>
      <div class="vl-hero-badge" data-reveal>
        <span class="vl-hero-badge-dot"></span>
        {{ properties.badge_text }}
      </div>

      <h1 class="vl-hero-title" data-reveal>
        {{ properties.title | renderString }}
      </h1>

      <p class="vl-hero-sub" data-reveal>
        {{ properties.subtitle | renderString }}
      </p>

      <div class="vl-hero-actions" data-reveal>
        <a href="{{ properties.cta }}" class="vl-btn-primary">
          {{ properties.cta_text }}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        {% if shop.discord_url or properties.cta_2 %}
        <a href="{{ shop.discord_url if shop.discord_url else properties.cta_2 }}" class="vl-btn-ghost" target="_blank" rel="noopener">
          {{ properties.cta_text_2 }}
        </a>
        {% endif %}
      </div>
    </div>

    <div class="vl-dashboard" data-reveal="scale">
      <div class="vl-dashboard-shell">
        <aside class="vl-dash-sidebar">
          <div class="vl-dash-brand">
            <span class="vl-dash-logo"></span>
            Velora
          </div>
          <nav class="vl-dash-nav">
            <span class="is-active"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>Catalog</span>
            <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/></svg>Orders</span>
            <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z"/></svg>Support</span>
          </nav>
        </aside>

        <div class="vl-dash-main">
          <div class="vl-dash-header">
            <div>
              <div class="vl-dash-greeting">Instant delivery</div>
              <div class="vl-dash-heading">Browse the catalog</div>
            </div>
            <a href="{{ properties.cta }}" class="vl-dash-cta-sm">Shop now</a>
          </div>

          <div class="vl-dash-products">
            <div class="vl-dash-products-head">
              <span>Popular products</span>
              <a href="{{ properties.cta }}">View all →</a>
            </div>
            <div class="vl-dash-grid">
              {% set heroItems = sortedItems | default([]) %}
              {% for product in heroItems if product.type != 'group' %}
                {% if loop.index <= 4 %}
                <a class="vl-dash-tile" href="{{ ('/product/' + product.path) | shopUrl }}">
                  <div class="vl-dash-tile-img">
                    {% if product.image_urls|length > 0 %}
                      <img src="{{ product.image_urls[0] }}" alt="{{ product.name }}" loading="lazy" />
                    {% elif product.image_url %}
                      <img src="{{ product.image_url }}" alt="{{ product.name }}" loading="lazy" />
                    {% else %}
                      <span class="vl-dash-tile-ph">{{ product.name | truncate(1, true, '') }}</span>
                    {% endif %}
                  </div>
                  <span class="vl-dash-tile-name">{{ product.name | truncate(22, true, '…') }}</span>
                  {% if product.min_price %}
                  <span class="vl-dash-tile-price">{{ formatPrice(product.min_price, product.currency) }}</span>
                  {% endif %}
                </a>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
      <div class="vl-dashboard-fade" aria-hidden="true"></div>
    </div>
  </div>

  {% if properties.show_searchbar %}
  <div class="modal fade search-modal" id="searchModal" x-data="searchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <div class="form-group searchbar">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="#626262" viewBox="0 0 256 256"><path d="M229.66,218.34l-50.07-50.06a88.11,88.11,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.32ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"></path></svg>
            <input type="text" class="form-control" placeholder="Search for products..." x-model="term">
          </div>
        </div>
        <div class="modal-body">
          <div class="products" x-ref="productsContainer">
            {% for product in sortedItems %}
              {% if product.type != 'group' %}
                <a href="{{ ('/product/' + product.path) | shopUrl }}" class="product" data-title="{{ product.name }}">
                  <div class="left">
                    <div class="image">
                      {% if product.image_urls|length > 0 %}
                        <img src="{{ product.image_urls[0] }}" class="img-fluid" alt="{{ product.name }}" loading="lazy" />
                      {% elif product.image_url %}
                        <img src="{{ product.image_url }}" class="img-fluid" alt="{{ product.name }}" loading="lazy" />
                      {% else %}
                        <div class="product-img-placeholder" style="color: var(--blue-primary);">
                          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 256 256">
                            <path fill="currentColor" d="m222.72 67.91l-88-48.18a13.9 13.9 0 0 0-13.44 0l-88 48.18A14 14 0 0 0 26 80.18v95.64a14 14 0 0 0 7.28 12.27l88 48.18a13.92 13.92 0 0 0 13.44 0l88-48.18a14 14 0 0 0 7.28-12.27V80.18a14 14 0 0 0-7.28-12.27ZM127 30.25a2 2 0 0 1 1.92 0L212.51 76l-33.94 18.57l-84.52-46.26ZM122 223l-83-45.43a2 2 0 0 1-1-1.75V86.66l84 46ZM43.49 76l38.07-20.85l84.51 46.26L128 122.24ZM218 175.82a2 2 0 0 1-1 1.75L134 223v-90.36l36-19.71V152a6 6 0 0 0 12 0v-45.63l36-19.71Z"/>
                          </svg>
                        </div>
                      {% endif %}
                    </div>
                    <div class="text">
                      <h3 class="product-name">{{ product.name }}</h3>
                      <p class="product-stock text-primary">
                        {% if product.stock === 0 %}Out of Stock
                        {% elif product.hide_stock_count %}In Stock
                        {% elif product.stock === -1 %}In Stock
                        {% else %}{{ product.stock }} In Stock{% endif %}
                      </p>
                      <p class="product-price">
                        <span class="price-label">Price:</span>
                        {% if product.min_price != product.max_price %}
                          <span x-text="appCurrency.format({{ product.min_price }}, '{{ product.currency }}')"></span>
                          <span> - </span>
                          <span x-text="appCurrency.format({{ product.max_price }}, '{{ product.currency }}')"></span>
                        {% elif product.min_price %}
                          <span x-text="appCurrency.format({{ product.min_price }}, '{{ product.currency }}')"></span>
                        {% else %}<span class="no-price">-</span>{% endif %}
                      </p>
                    </div>
                  </div>
                  <div class="right">
                    <svg width="24px" height="24px" class="arrow-icon" viewBox="0 0 24 24" fill="none"><path d="M11 16L15 12M15 12L11 8M15 12H3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                  </div>
                </a>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
  <script>
    document.addEventListener('alpine:init', () => {
      Alpine.data('searchModal', () => ({
        term: '',
        init() {
          this.$watch('term', () => {
            this.$refs.productsContainer.querySelectorAll('.product').forEach((product) => {
              if (product.dataset.title.toLowerCase().includes(this.term.toLowerCase())) {
                product.classList.remove('d-none');
              } else {
                product.classList.add('d-none');
              }
            });
          });
        }
      }));
    });
    document.querySelector('.search-modal')?.addEventListener('shown.bs.modal', function() {
      this.querySelector('.searchbar input')?.focus();
    });
  </script>
  {% endif %}
</section>
