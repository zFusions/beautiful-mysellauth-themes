<section id="products" class="ps-section component" data-component-id="{{ componentId }}">
  <div class="container">
    <header class="ps-head ps-head-produce" data-reveal>
      <h2 class="ps-title ps-title-stack">{{ properties.title | renderString }}</h2>
      <div class="ps-brand-row">
        <span class="ps-brand-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z"/></svg>
        </span>
        <span class="ps-brand-text">Shop Velora Market</span>
      </div>
    </header>

  <div id="categories" class="search-filter-wrapper mb-5" data-reveal>
    <div class="search-box-modern">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-icon"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input type="text" id="product-search" placeholder="Search products..." class="search-input-modern">
    </div>
  </div>

  <div id="no-products-message" class="ps-empty-search text-center py-20" style="display: none;">
    <div class="ps-empty-search-icon mb-4" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        <line x1="8" y1="11" x2="14" y2="11"></line>
      </svg>
    </div>
    <h3 class="ps-title ps-empty-search-title">No matching products</h3>
    <p class="ps-subtitle ps-empty-search-sub">
      We couldn't find anything matching your search. Try a different keyword or browse the full catalog.
    </p>
    <button type="button" onclick="document.getElementById('product-search').value = ''; document.getElementById('product-search').dispatchEvent(new Event('input'));" class="ps-btn-ghost ps-empty-search-clear mt-4">
      Clear search
    </button>
  </div>

  <div class="products-grid-wrap" id="products-grid" data-reveal-group>
    {% if (properties.ids | default([])) | length == 0 %}
      {% for product in sortedItems %}
        {% if product.type == 'group' or not product.group_id %}
          {% render_snippet "product-card.njk", product=product %}
        {% endif %}
      {% endfor %}
    {% else %}
      {% for product in helpers.components.products.getItemsByIds(sortedItems, properties.ids) %}
        {% render_snippet "product-card.njk", product=product %}
      {% endfor %}
    {% endif %}
  </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('product-search');
  const productsGrid = document.getElementById('products-grid');
  const noProductsMessage = document.getElementById('no-products-message');
  const categoryTabs = document.querySelectorAll('.velora-tab');

  let activeCategory = null;

  function filterProducts() {
    const searchTerm = searchInput.value.toLowerCase().trim();
    const productCards = productsGrid.querySelectorAll('.product-card-container');
    let visibleCount = 0;

    productCards.forEach(card => {
      const productName = card.getAttribute('data-product-name').toLowerCase();
      const productCategory = card.getAttribute('data-product-category');

      const matchesSearch = productName.includes(searchTerm);
      const matchesCategory = !activeCategory || productCategory === activeCategory;

      if (matchesSearch && matchesCategory) {
        card.style.display = 'block';
        card.classList.add('is-visible');
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    if (visibleCount === 0) {
      noProductsMessage.style.display = 'block';
      productsGrid.style.display = 'none';
    } else {
      noProductsMessage.style.display = 'none';
      productsGrid.style.display = 'grid';
    }
  }

  if (searchInput) {
    searchInput.addEventListener('input', filterProducts);
  }

  categoryTabs.forEach(tab => {
    tab.addEventListener('click', function() {
      if (this.classList.contains('active')) {
        this.classList.remove('active');
        activeCategory = null;
      } else {
        categoryTabs.forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        activeCategory = this.textContent.trim();
      }
      filterProducts();
    });
  });
});
</script>

<style>
  #products {
    padding-top: clamp(48px, 6vw, 72px);
    padding-bottom: clamp(64px, 8vw, 96px);
  }

  #products .ps-empty-search {
    max-width: 480px;
    margin: 0 auto;
  }

  #products .ps-empty-search-icon {
    color: var(--border-strong);
    opacity: 0.45;
  }

  #products .ps-empty-search-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 0.75rem;
  }

  #products .ps-empty-search-sub {
    margin-left: auto;
    margin-right: auto;
  }

  #products .ps-empty-search-clear {
    margin-top: 1rem;
  }

  #products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  #products-grid > .product-card-container {
    margin-bottom: 0 !important;
    padding: 0;
    width: 100%;
    max-width: none;
  }

  .search-filter-wrapper {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 1.5rem;
    width: 100%;
    margin: 0 0 2rem;
  }

  .search-box-modern {
    position: relative;
    width: 100%;
    max-width: none;
  }

  .search-icon {
    position: absolute;
    left: 1.1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-secondary);
    pointer-events: none;
  }

  .search-input-modern {
    width: 100%;
    background: var(--bg-surface);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-pill);
    padding: 0.8rem 1rem 0.8rem 3rem;
    color: var(--produce-hero-color, #0A0B10);
    font-size: var(--produce-body-size, 16px);
    font-weight: 500;
    line-height: var(--produce-body-lh, 24px);
    letter-spacing: var(--produce-body-ls, -0.3px);
    transition: all 0.2s ease;
  }

  .search-input-modern:focus {
    background: #fff;
    border-color: var(--blue-primary);
    box-shadow: 0 0 0 3px rgba(27, 68, 254, 0.12);
    outline: none;
  }

  .velora-tabs-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 0.6rem;
  }

  .velora-tab {
    background: #fff;
    border: 1px solid var(--border-default);
    color: var(--text-secondary);
    font-weight: 600;
    padding: 8px 18px;
    border-radius: var(--radius-pill);
    transition: all 0.2s ease;
    cursor: pointer;
    font-size: 0.85rem;
  }

  .velora-tab:hover {
    background: var(--bg-surface);
    color: var(--text-primary);
    border-color: var(--border-strong);
  }

  .velora-tab.active {
    background: var(--blue-primary);
    border-color: var(--blue-primary);
    color: #fff;
  }
</style>

{% for product in sortedItems %}
  {% if product.type == 'group' %}
    <div class="modal fade group-products-modal" id="group-modal-{{ product.id }}" tabindex="-1" aria-labelledby="group-modal-{{ product.id }}-label" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="group-modal-{{ product.id }}-label">
              {{ product.name }} Products
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="products row">
              {% for product in product.products %}
                {% render_snippet "product-card.njk", product=product %}
              {% endfor %}
            </div>
          </div>
        </div>
    </div>
  </div>
{% endif %}
{% endfor %}

<style>
  .group-products-modal .modal-content {
    background: #ffffff;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .group-products-modal .modal-header {
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border-default);
    padding: 1.25rem 1.5rem;
  }

  .group-products-modal .modal-title {
    color: var(--text-primary);
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.01em;
    font-size: 1.2rem;
    display: flex;
    align-items: center;
  }

  .group-products-modal .modal-body { background: #fff; }
</style>
