<div class="container component" data-component-id="{{ componentId }}">
  <section class="py-5-nav">
    <div class="row">
      <div class="col-12 col-lg-3 mb-4">
        {% render_snippet "customer-sidebar.njk" %}
      </div>
      <div class="col-12 col-lg-9">
        <div class="card p-4">
          <table class="table">
            <thead>
              <tr>
                <th scope="col">Status</th>
                <th scope="col">ID</th>
                <th scope="col">Products</th>
                <th scope="col">Price</th>
                <th scope="col">Date</th>
              </tr>
            </thead>
            <tbody>
              {% if invoices.data.length > 0 %}
                {% for invoice in invoices.data %}
                  <tr class="small">
                    <td class="text-capitalize">{{ invoice.status | replace('_', ' ') }}</td>
                    <td><a href="{{ invoice.url }}" target="_blank" class="text-accent-500">#{{ invoice.unique_id }}</a></td>
                    <td>
                      {% if invoice.items %}
                        {{ invoice.items[0].product.name }} 
                        {% if invoice.items[0].variant and invoice.items[0].product.name != invoice.items[0].variant.name %}
                          ({{ invoice.items[0].variant.name }})
                        {% endif %}

                        {% if invoice.items.length > 1 %}
                          & {{ invoice.items.length - 1 }} more
                        {% endif %}
                      {% else %}
                        Unknown Product
                      {% endif %}
                    </td>
                    <td>{{ formatPrice(invoice.price, invoice.currency) }}</td>
                    <td>{{ invoice.created_at | formatDate }}</td>
                  </tr>
                {% endfor %}
              {% else %}
                <tr>
                  <td colspan="5" class="text-center">No Orders Yet</td>
                </tr>
              {% endif %}
            </tbody>
          </table>
        </div>

        {% if invoices.last_page > 1 %}
          {% render_snippet "pagination.njk", paginator=invoices %}
        {% endif %}
      </div>
    </div>
  </section>
</div>

<div class="components">
  {% for componentId in components_order %}
    {% render_component componentId %}
  {% endfor %}
</div>

<style>
  [data-component-id="{{ componentId }}"] .card {
    background: #ffffff;
    border: 1px solid var(--border-default, #e8e8e9);
    border-radius: 1rem;
    box-shadow: var(--shadow-card, 0 1px 2px rgba(16,24,40,0.04), 0 4px 16px rgba(16,24,40,0.06));
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  [data-component-id="{{ componentId }}"] .table {
    --bs-table-bg: transparent;
    --bs-table-color: var(--text-primary, #0a0a0a);
    --bs-table-border-color: var(--border-default, #e8e8e9);
    color: var(--text-primary, #0a0a0a);
  }

  [data-component-id="{{ componentId }}"] .table thead th {
    color: var(--text-secondary, #7a7a7a);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    border-bottom-color: var(--border-default, #e8e8e9);
  }

  [data-component-id="{{ componentId }}"] .table td,
  [data-component-id="{{ componentId }}"] .table th {
    border-color: var(--border-default, #eef0f2);
    vertical-align: middle;
  }

  [data-component-id="{{ componentId }}"] a.text-accent-500 {
    color: var(--blue-primary, #1B44FE);
    text-decoration: none;
    border-bottom: none;
    font-weight: 600;
  }

  [data-component-id="{{ componentId }}"] a.text-accent-500:hover {
    color: var(--blue-deep, #0000ee);
    text-decoration: underline;
  }
</style>