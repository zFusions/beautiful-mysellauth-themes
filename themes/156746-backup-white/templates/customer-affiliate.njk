<div class="container component" data-component-id="{{ componentId }}">
  <section class="py-5-nav">
    <div class="row">
      <div class="col-12 col-lg-3 mb-4">
        {% render_snippet "customer-sidebar.njk" %}
      </div>
      <div class="col-12 col-lg-9">
        <div class="row">
          <div class="col-12 col-md-6 mb-4">
            <div class="card h-100 p-4">
              <h4 class="text-lg text-t-primary/80">
                Your Affiliate Link
              </h4>
              <p class="small">
                Share your affiliate link with friends and earn rewards when they make purchases.
              </p>
              <div
                class="d-flex justify-content-between align-items-center gap-2 mt-3"
                x-data="{
                  copied: false,
                  copy() {
                    const affiliateLink = $refs.affiliateLink;
                    navigator.clipboard.writeText(affiliateLink.textContent).then(() => {
                      this.copied = true;
                      setTimeout(() => {
                        this.copied = false;
                      }, 2000);
                    })
                  }
                }"
              >
                <button
                  type="button"
                  class="btn btn-link text-start p-0 text-decoration-none fw-semibold text-truncate flex-grow-1"
                  x-ref="affiliateLink"
                  @click="copy()"
                  :disabled="copied"
                >
                  {{ shop.url }}/?a={{ shop_customer.affiliate_code }}
                </button>
                <template x-if="copied">
                  <span class="text-accent-500 fw-bold">Copied!</span>
                </template>
              </div>
            </div>
          </div>
          <div class="col-12 col-md-6 mb-4">
            <div class="card h-100 p-4">
              <h4 class="text-lg text-t-primary/80">
                Affiliate Rewards
              </h4>
              <p class="small">
                You earn a percentage of the total invoice amount for each purchase made through your affiliate link.
              </p>
              <h5 class="mb-0 mt-3">
                {{ shop.affiliate_percentage }}%
              </h5>
            </div>
          </div>
          <div class="col-12 col-md-6 mb-4">
            <a href="{{ '/customer/balance' | shopUrl }}" class="card text-decoration-none h-100 p-4">
              <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                  View Your Balance
                </h5>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 256 256">
                  <path d="M224,104a8,8,0,0,1-16,0V59.32l-66.33,66.34a8,8,0,0,1-11.32-11.32L196.68,48H152a8,8,0,0,1,0-16h64a8,8,0,0,1,8,8Zm-40,24a8,8,0,0,0-8,8v72H48V80h72a8,8,0,0,0,0-16H48A16,16,0,0,0,32,80V208a16,16,0,0,0,16-16V136A8,8,0,0,0,184,128Z"></path>
                </svg>
              </div>
            </a>
          </div>
          <div class="col-12 col-md-6 mb-4">
            <a href="{{ '/customer/balance' | shopUrl }}" class="card text-decoration-none h-100 p-4">
              <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                  View Your Balance History
                </h5>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 256 256">
                  <path d="M224,104a8,8,0,0,1-16,0V59.32l-66.33,66.34a8,8,0,0,1-11.32-11.32L196.68,48H152a8,8,0,0,1,0-16h64a8,8,0,0,1,8,8Zm-40,24a8,8,0,0,0-8,8v72H48V80h72a8,8,0,0,0,0-16H48A16,16,0,0,0,32,80V208a16,16,0,0,0,16-16V136A8,8,0,0,0,184,128Z"></path>
                </svg>
              </div>
            </a>
          </div>
        </div>
        <div class="card p-4">
          <h5>
            Referred Users
          </h5>
          <table class="table">
            <thead>
              <tr>
                <th scope="col">E-mail Address</th>
                <th scope="col">Amount Earned</th>
                <th scope="col">Date</th>
              </tr>
            </thead>
            <tbody>
              {% if referred_customers.data.length > 0 %}
                {% for customer in referred_customers.data %}
                  <tr class="small">
                    <td class="text-capitalize">{{ customer.email }}</td>
                    <td class="text-capitalize">
                      <span x-text="appCurrency.format({{ customer.affiliate_referrer_earnings }}, 'USD')">
                        {{ formatPrice(customer.affiliate_referrer_earnings, 'USD') }}
                      </span>
                    </td>
                    <td>{{ customer.created_at | formatDateTime }}</td>
                  </tr>
                {% endfor %}
              {% else %}
                <tr>
                  <td colspan="3" class="text-center">No referred customers yet.</td>
                </tr>
              {% endif %}
            </tbody>
          </table>
        </div>
    
        {% if referred_customers.last_page > 1 %}
          {% render_snippet "pagination.njk", paginator=referred_customers %}
        {% endif %}
      </div>
    </div>
  </section>
</div>

<div class="components">
  {% for componentId in components_order %}
    {% render_component componentId %}
  {% endfor %}
</div>

<style>
  [data-component-id="{{ componentId }}"] .card {
    background: #ffffff;
    border: 1px solid var(--border-default, #e8e8e9);
    border-radius: 1rem;
    box-shadow: var(--shadow-card, 0 1px 2px rgba(16,24,40,0.04), 0 4px 16px rgba(16,24,40,0.06));
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    color: var(--text-primary, #0a0a0a);
  }

  [data-component-id="{{ componentId }}"] .card h4 { color: var(--text-secondary, #7a7a7a); font-weight: 600; }
  [data-component-id="{{ componentId }}"] .card h5 { color: var(--text-primary, #0a0a0a); font-weight: 700; }
  [data-component-id="{{ componentId }}"] .card p.small { color: var(--text-secondary, #7a7a7a); }

  [data-component-id="{{ componentId }}"] a.card {
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }
  [data-component-id="{{ componentId }}"] a.card:hover {
    transform: translateY(-2px);
    border-color: rgba(27, 68, 254, 0.35);
    box-shadow: 0 10px 30px rgba(27, 68, 254, 0.12);
  }
  [data-component-id="{{ componentId }}"] a.card svg { color: var(--blue-primary, #1B44FE); }

  [data-component-id="{{ componentId }}"] .btn.btn-link {
    color: var(--blue-primary, #1B44FE);
    border-bottom: none;
  }

  [data-component-id="{{ componentId }}"] .btn.btn-link:hover {
    color: var(--blue-deep, #0000ee);
    text-decoration: underline;
  }

  [data-component-id="{{ componentId }}"] .text-accent-500 {
    color: var(--blue-primary, #1B44FE) !important;
  }

  [data-component-id="{{ componentId }}"] .table {
    --bs-table-bg: transparent;
    --bs-table-color: var(--text-primary, #0a0a0a);
    --bs-table-border-color: var(--border-default, #e8e8e9);
    color: var(--text-primary, #0a0a0a);
  }

  [data-component-id="{{ componentId }}"] .table thead th {
    color: var(--text-secondary, #7a7a7a);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    border-bottom-color: var(--border-default, #e8e8e9);
  }

  [data-component-id="{{ componentId }}"] .table td,
  [data-component-id="{{ componentId }}"] .table th {
    border-color: var(--border-default, #eef0f2);
    vertical-align: middle;
  }
</style>