{% set statusLabelMap = {
  'pending': 'Awaiting Your Response',
  'open': 'Awaiting Support Response',
  'closed': 'Closed'
} %}

<div class="container component" data-component-id="{{ componentId }}">
  <section class="py-5-nav">
    <div class="row">
      <div class="col-12 col-lg-3 mb-4">
        {% render_snippet "customer-sidebar.njk" %}
      </div>
      <div class="col-12 col-lg-9">
        <div class="alert alert-info d-flex align-items-center mb-4" role="alert">
          <i class="fa fa-info-circle me-2"></i>
          <div class="flex-grow-1">
            <small>
              You can open a new ticket on the <a href="{{ '/customer/invoices' | shopUrl }}" class="text-accent-500">Orders</a> page by clicking on the "Open Ticket" button next to an order.
            </small>
          </div>
        </div>
        
        <div class="card p-4">
          <h3 class="mb-4">Tickets</h3>
          
          {% if tickets.data.length > 0 %}
            <table class="table">
              <thead>
                <tr>
                  <th scope="col">Subject</th>
                  <th scope="col">Status</th>
                  <th scope="col">Opened At</th>
                </tr>
              </thead>
              <tbody>
                {% for ticket in tickets.data %}
                  <tr class="small">
                    <td>
                      <a href="{{ ('/customer/tickets/' ~ ticket.id) | shopUrl }}" class="text-accent-500">
                        {{ ticket.subject }}
                      </a>
                    </td>
                    <td>
                      {% if ticket.status in statusLabelMap %}
                        {{ statusLabelMap[ticket.status] }}
                      {% else %}
                        <span class="text-capitalize">{{ ticket.status | replace('_', ' ') }}</span>
                      {% endif %}
                    </td>
                    <td>{{ ticket.created_at | formatDateTime }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          {% else %}
            <div class="text-center py-4">
              <p class="text-muted mb-0">No Tickets Yet</p>
            </div>
          {% endif %}
          
          {% if tickets.last_page > 1 %}
            <div class="mt-4">
              {% render_snippet "pagination.njk", paginator=tickets %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  [data-component-id="{{ componentId }}"] .alert {
    background: var(--blue-glow, rgba(27,68,254,0.06));
    border: 1px solid rgba(27, 68, 254, 0.18);
    color: var(--text-primary, #0a0a0a);
    border-radius: 0.85rem;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  [data-component-id="{{ componentId }}"] .alert .text-accent-500 { color: var(--blue-primary, #1B44FE); font-weight: 600; }

  [data-component-id="{{ componentId }}"] .card {
    background: #ffffff;
    border: 1px solid var(--border-default, #e8e8e9);
    border-radius: 1rem;
    box-shadow: var(--shadow-card, 0 1px 2px rgba(16,24,40,0.04), 0 4px 16px rgba(16,24,40,0.06));
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  [data-component-id="{{ componentId }}"] .card h3 { color: var(--text-primary, #0a0a0a); font-weight: 700; }

  [data-component-id="{{ componentId }}"] .table {
    --bs-table-bg: transparent;
    --bs-table-color: var(--text-primary, #0a0a0a);
    --bs-table-border-color: var(--border-default, #e8e8e9);
    color: var(--text-primary, #0a0a0a);
  }

  [data-component-id="{{ componentId }}"] .table thead th {
    color: var(--text-secondary, #7a7a7a);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    border-bottom-color: var(--border-default, #e8e8e9);
  }

  [data-component-id="{{ componentId }}"] .table td { border-color: var(--border-default, #eef0f2); vertical-align: middle; }

  [data-component-id="{{ componentId }}"] a.text-accent-500 {
    color: var(--blue-primary, #1B44FE);
    text-decoration: none;
    border-bottom: none;
    font-weight: 600;
  }

  [data-component-id="{{ componentId }}"] a.text-accent-500:hover {
    color: var(--blue-deep, #0000ee);
    text-decoration: underline;
  }

  [data-component-id="{{ componentId }}"] .text-muted {
    color: var(--text-secondary, #7a7a7a) !important;
  }
</style>

<div class="components">
  {% for componentId in components_order %}
    {% render_component componentId %}
  {% endfor %}
</div>