<div class="product-card-container"
     data-reveal
     data-product-name="{{ product.name }}"
     data-product-category="{{ product.group_name if product.group_name else 'Uncategorized' }}">
  <a
    class="ps-product-card text-decoration-none"
    href="{{ 'javascript:void(0);' if product.type == 'group' else ( ('/product/' + product.path) | shopUrl ) }}"
    data-bs-toggle="{{ 'modal' if product.type == 'group' else '' }}"
    data-bs-target="{{ '#group-modal-' ~ product.id if product.type == 'group' else '' }}"
  >
    <div class="ps-product-media">
      {% if product.image_urls|length > 0 %}
        <img src="{{ product.image_urls[0] }}" loading="lazy" alt="{{ product.name }}" class="ps-product-img" />
      {% elif product.image_url %}
        <img src="{{ product.image_url }}" loading="lazy" alt="{{ product.name }}" class="ps-product-img" />
      {% else %}
        <div class="ps-product-placeholder" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 256 256">
            <path fill="currentColor" d="m222.72 67.91l-88-48.18a13.9 13.9 0 0 0-13.44 0l-88 48.18A14 14 0 0 0 26 80.18v95.64a14 14 0 0 0 7.28 12.27l88 48.18a13.92 13.92 0 0 0 13.44 0l88-48.18a14 14 0 0 0 7.28-12.27V80.18a14 14 0 0 0-7.28-12.27ZM127 30.25a2 2 0 0 1 1.92 0L212.51 76l-33.94 18.57l-84.52-46.26ZM122 223l-83-45.43a2 2 0 0 1-1-1.75V86.66l84 46ZM43.49 76l38.07-20.85l84.51 46.26L128 122.24ZM218 175.82a2 2 0 0 1-1 1.75L134 223v-90.36l36-19.71V152a6 6 0 0 0 12 0v-45.63l36-19.71Z"/>
          </svg>
        </div>
      {% endif %}

      {% if product.product_badges.card|length > 0 %}
        <div class="ps-product-badges">
          {% for productBadge in product.product_badges.card %}
            <span class="ps-product-badge">{{ productBadge.label }}</span>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="ps-product-body">
      <h3 class="ps-product-name">{{ product.name }}</h3>

      <div class="ps-product-meta">
        <div class="ps-product-prices">
          {% if product.min_price != product.max_price %}
            <span class="ps-product-price" x-text="appCurrency.format({{ product.min_price }}, '{{ product.currency }}')">
              {{ formatPrice(product.min_price, product.currency) }}
            </span>
          {% elif product.min_price %}
            <span class="ps-product-price" x-text="appCurrency.format({{ product.min_price }}, '{{ product.currency }}')">
              {{ formatPrice(product.min_price, product.currency) }}
            </span>
          {% else %}
            <span class="ps-product-price-muted">On request</span>
          {% endif %}

          {% if product.min_price_slash %}
            <span class="ps-product-price-old" x-text="appCurrency.format({{ product.min_price_slash }}, '{{ product.currency }}')">
              {{ formatPrice(product.min_price_slash, product.currency) }}
            </span>
          {% endif %}
        </div>

        {% if product.stock !== 0 %}
        <span class="ps-product-stock">In stock</span>
        {% endif %}
      </div>

      <span class="ps-product-cta {{ 'is-disabled' if product.stock === 0 }}">
        <span>{{ 'Out of stock' if product.stock === 0 else 'Quick buy' }}</span>
        {% if product.stock !== 0 %}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
        {% endif %}
      </span>
    </div>
  </a>
</div>

<style>
.ps-product-card {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #ffffff;
  border: 1px solid var(--border-default);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: transform 0.2s ease, border-color 0.2s ease;
  position: relative;
}

.ps-product-card:hover {
  transform: translateY(-3px);
  border-color: var(--border-strong);
}

.ps-product-card:focus-visible {
  outline: 2px solid var(--blue-primary);
  outline-offset: 2px;
}

.ps-product-media {
  background: #f3f3f5;
  padding: 1.5rem;
  text-align: center;
  position: relative;
  min-height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1px solid var(--border-default);
}

.ps-product-img {
  max-width: 82%;
  max-height: 160px;
  object-fit: contain;
  transition: transform 0.25s ease;
}

.ps-product-card:hover .ps-product-img {
  transform: scale(1.03);
}

.ps-product-placeholder { color: var(--border-strong); }

.ps-product-badges {
  position: absolute;
  top: 0.75rem;
  left: 0.75rem;
  display: flex;
  gap: 0.35rem;
  flex-wrap: wrap;
}

.ps-product-badge {
  background: rgba(27, 68, 254, 0.08);
  padding: 4px 10px;
  border-radius: var(--radius-sm);
  font-size: 0.72rem;
  color: var(--blue-primary);
  font-weight: 600;
  letter-spacing: -0.01em;
  border: 1px solid rgba(27, 68, 254, 0.14);
}

.ps-product-body {
  padding: 1.15rem 1.15rem 1.25rem;
  display: flex;
  flex-direction: column;
  flex: 1;
  gap: 0.85rem;
}

.ps-product-name {
  color: var(--produce-card-title-color, #0A0B10);
  font-family: var(--font-display);
  font-size: var(--produce-card-title-size, 24px);
  font-weight: 600;
  line-height: var(--produce-card-title-lh, 28.8px);
  letter-spacing: var(--produce-card-title-ls, -0.03em);
  margin: 0;
}

.ps-product-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
}

.ps-product-prices {
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.ps-product-price {
  color: var(--text-primary);
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 600;
  letter-spacing: -0.02em;
}

.ps-product-price-muted {
  color: var(--text-secondary);
  font-weight: 500;
}

.ps-product-price-old {
  font-size: 0.875rem;
  color: var(--text-muted);
  text-decoration: line-through;
  font-weight: 500;
}

.ps-product-stock {
  font-weight: 600;
  font-size: 0.75rem;
  letter-spacing: -0.01em;
  color: var(--color-success);
  background: rgba(46, 125, 50, 0.08);
  padding: 4px 10px;
  border-radius: var(--radius-pill);
}

.ps-product-cta {
  margin-top: auto;
  width: 100%;
  background: var(--blue-primary);
  border: none;
  color: #fff;
  font-weight: 600;
  font-size: 0.9rem;
  padding: 12px;
  border-radius: var(--radius-sm);
  transition: background 0.2s ease, transform 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.ps-product-card:hover .ps-product-cta:not(.is-disabled) {
  background: #1640e8;
}

.ps-product-cta.is-disabled {
  background: #f3f3f5;
  border: 1px solid var(--border-default);
  color: var(--text-muted);
}

@media (prefers-reduced-motion: reduce) {
  .ps-product-card,
  .ps-product-img,
  .ps-product-cta { transition: none; }
  .ps-product-card:hover { transform: none; }
}
</style>
