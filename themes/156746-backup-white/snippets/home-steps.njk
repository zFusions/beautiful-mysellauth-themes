<section id="how-it-works" class="ps-section component">
  <div class="container">
    <header class="ps-head ps-head-produce" data-reveal>
      <h2 class="ps-title ps-title-stack">Three simple steps.<br>Browse, pay &amp; receive<br>your order instantly.</h2>
      <div class="ps-brand-row">
        <span class="ps-brand-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z"/></svg>
        </span>
        <span class="ps-brand-text">How Velora works</span>
      </div>
      <p class="ps-subtitle ps-steps-lead">Pick a product, pay securely, and get it delivered automatically — no waiting, no hassle.</p>
    </header>

    <div class="vl-produce-grid" data-reveal-group>
      <article class="vl-produce-card" data-reveal>
        <div class="vl-produce-mock" aria-hidden="true">
          <div class="vl-produce-mock-inner">
            <div class="vl-produce-input-row">
              <span class="vl-produce-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M20 20l-3-3"/></svg>
              </span>
              <span class="vl-produce-field">Search products…</span>
            </div>
            <span class="vl-produce-btn">Add to cart</span>
          </div>
        </div>
        <div class="vl-produce-body">
          <span class="vl-produce-step">Step 1</span>
          <h3 class="vl-produce-title">Pick your product</h3>
          <p class="vl-produce-text">Browse the catalog, compare prices, and add what you need — no account required.</p>
        </div>
      </article>

      <article class="vl-produce-card" data-reveal>
        <div class="vl-produce-mock" aria-hidden="true">
          <div class="vl-produce-mock-inner">
            <span class="vl-produce-amount">€24.99</span>
            <div class="vl-produce-pay-tabs">
              <span class="is-on">Card</span>
              <span>Crypto</span>
              <span>PayPal</span>
            </div>
            <div class="vl-produce-card-field">
              <span></span>
              <span class="w40"></span>
            </div>
            <span class="vl-produce-btn">Pay securely</span>
          </div>
        </div>
        <div class="vl-produce-body">
          <span class="vl-produce-step">Step 2</span>
          <h3 class="vl-produce-title">Checkout securely</h3>
          <p class="vl-produce-text">Pay with Visa, crypto, or PayPal. Every transaction is encrypted end-to-end.</p>
        </div>
      </article>

      <article class="vl-produce-card" data-reveal>
        <div class="vl-produce-mock" aria-hidden="true">
          <div class="vl-produce-mock-inner">
            <div class="vl-produce-track">
              <div class="vl-produce-track-row is-done"><i></i><span>Payment confirmed</span></div>
              <div class="vl-produce-track-row is-done"><i></i><span>Order processing</span></div>
              <div class="vl-produce-track-row is-active"><i></i><span>Delivered to you</span></div>
            </div>
          </div>
        </div>
        <div class="vl-produce-body">
          <span class="vl-produce-step">Step 3</span>
          <h3 class="vl-produce-title">Instant delivery</h3>
          <p class="vl-produce-text">Your order is sent automatically the moment payment is confirmed — 24/7.</p>
        </div>
      </article>
    </div>
  </div>
</section>
