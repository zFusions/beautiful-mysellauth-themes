<div class="modal fade" id="admin-login-modal" tabindex="-1" aria-labelledby="admin-login-modal-label" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="admin-login-modal-label">
          Admin Access
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form @submit.prevent="appMaintenance.modalLogin()">
          <div class="mb-1">
            <label class="mb-0 form-label">
              Password
            </label>
            <small class="d-block form-text">
              Enter the maintenance password to access admin functions.
            </small>
          </div>
          <div class="mt-2">
            <input 
              type="password"
              x-model="appMaintenance.modalPassword"
              x-ref="appMaintenance.modalPasswordInput"
              placeholder="Enter the maintenance password"
              class="form-control"
            />
          </div>
          <p x-show="appMaintenance.modalError" class="form-text text-danger" x-text="appMaintenance.modalError"></p>
          <button 
            type="submit"
            class="btn btn-primary mt-3 w-100"
            :disabled="appMaintenance.modalLoading"
          >
            <span>Login</span>
            <template x-if="!appMaintenance.modalLoading">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M13 21q-.425 0-.712-.288T12 20t.288-.712T13 19h6V5h-6q-.425 0-.712-.288T12 4t.288-.712T13 3h6q.825 0 1.413.588T21 5v14q0 .825-.587 1.413T19 21zm-1.825-8H4q-.425 0-.712-.288T3 12t.288-.712T4 11h7.175L9.3 9.125q-.275-.275-.275-.675t.275-.7t.7-.313t.725.288L14.3 11.3q.3.3.3.7t-.3.7l-3.575 3.575q-.3.3-.712.288T9.3 16.25q-.275-.3-.262-.712t.287-.688z"/></svg>
            </template>
            <template x-if="appMaintenance.modalLoading">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-dasharray="16" stroke-dashoffset="16" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3c4.97 0 9 4.03 9 9"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.2s" values="16;0"/><animateTransform attributeName="transform" dur="1.5s" repeatCount="indefinite" type="rotate" values="0 12 12;360 12 12"/></path></svg>
            </template>
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<style>
  #admin-login-modal .modal-content {
    background: #ffffff;
    border: 1px solid var(--border-default, #e8e8e9);
    border-radius: 1.25rem;
    box-shadow: 0 24px 70px rgba(16, 24, 40, 0.18);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    overflow: hidden;
  }

  #admin-login-modal .modal-header {
    background: #ffffff;
    border-bottom: 1px solid var(--border-default, #eef0f2);
  }

  #admin-login-modal .modal-title {
    color: var(--text-primary, #0a0a0a);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  #admin-login-modal .modal-body {
    background: #ffffff;
    color: var(--text-secondary, #5c5c5c);
  }

  #admin-login-modal .form-label {
    color: var(--text-primary, #0a0a0a);
    font-weight: 600;
  }

  #admin-login-modal .form-text {
    color: var(--text-secondary, #7a7a7a);
  }

  #admin-login-modal .btn-close {
    filter: none;
    opacity: 0.6;
  }

  #admin-login-modal .btn-close:hover {
    opacity: 1;
  }

  #admin-login-modal input.form-control {
    background: #ffffff;
    border: 1px solid var(--border-default, #d8d8da);
    color: var(--text-primary, #0a0a0a);
    border-radius: 0.7rem;
  }

  #admin-login-modal input.form-control::placeholder {
    color: var(--text-tertiary, #9a9a9a);
  }

  #admin-login-modal input.form-control:focus {
    border-color: var(--blue-primary, #1B44FE);
    box-shadow: 0 0 0 0.2rem var(--blue-glow, rgba(27,68,254,0.12));
  }

  #admin-login-modal .btn.btn-primary {
    border-radius: 0.7rem;
    background: var(--blue-primary, #1B44FE);
    border: none;
    color: #fff;
    font-weight: 700;
  }
  #admin-login-modal .btn.btn-primary:hover { background: var(--blue-deep, #0000ee); }
</style>