<style>
  .home-cta { padding: 48px 0 80px; }

  .home-cta-card {
    max-width: min(720px, 100%);
    margin: 0 auto;
    background: #ffffff;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: clamp(40px, 6vw, 56px) clamp(24px, 4vw, 40px);
    text-align: center;
  }

  .home-cta-content { max-width: 520px; margin: 0 auto; }

  .home-cta-kicker {
    margin: 0 0 16px;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--blue-primary);
  }

  .home-cta-title {
    color: var(--produce-section-color, #151621);
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 600;
    letter-spacing: var(--produce-section-ls, -0.03em);
    line-height: 1.12;
    margin: 0 0 12px;
    font-synthesis: none;
    text-wrap: balance;
  }

  .home-cta-sub {
    color: var(--produce-body-color, #626262);
    font-size: var(--produce-body-size, 16px);
    font-weight: 500;
    line-height: var(--produce-body-lh, 24px);
    letter-spacing: var(--produce-body-ls, -0.3px);
    margin: 0 0 28px;
    text-wrap: pretty;
  }

  .home-cta-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .home-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 24px;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
  }

  .home-cta-btn-primary {
    background: var(--blue-primary);
    color: #fff;
  }

  .home-cta-btn-primary:hover {
    background: #1640e8;
    color: #fff;
    transform: translateY(-1px);
  }

  .home-cta-btn-ghost {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border-default);
  }

  .home-cta-btn-ghost:hover {
    border-color: var(--border-strong);
    color: var(--text-primary);
    transform: translateY(-1px);
  }

  .home-cta-btn:focus-visible {
    outline: 2px solid var(--blue-primary);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .home-cta-btn { transition: none; }
    .home-cta-btn:hover { transform: none; }
  }
</style>
