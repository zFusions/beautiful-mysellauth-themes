<article class="vl-review-card">
  <div class="vl-review-card-top">
    <div class="vl-review-stars" aria-label="{{ feedback.rating }} out of 5 stars">
      {% for i in range(0, feedback.rating) %}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      {% endfor %}
    </div>
    <time class="vl-review-date" datetime="{{ feedback.created_at }}">{{ feedback.created_at | formatDate }}</time>
  </div>
  <p class="vl-review-text">{{ feedback.message | safe | truncate(120, true, '…') }}</p>
  <div class="vl-review-card-foot">
    <span class="vl-review-author">Verified Customer</span>
    <span class="vl-review-badge">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
      Verified
    </span>
  </div>
</article>
