<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {% render_snippet "meta-tags.njk" %}

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />

    <style id="theme-styles">
      {% set themeFont = global.properties.font if global.properties.font else 'Poppins' %}
      {% set cleanFont = themeFont | replace(' (Deprecated)', '') %}
      {% set fontLower = cleanFont | lower %}
      {% set isInterFamily = 'inter' in fontLower %}
      {% set isSemiBold = 'semi bold' in fontLower or 'semibold' in fontLower %}
      {% set cssFont = 'Inter' if isInterFamily else cleanFont %}
      {% set googleFont = cssFont | replace(' ', '+') %}
      {% set themeFontWeight = 600 if isSemiBold else 400 %}
      {% set themeHeadingWeight = 600 if isSemiBold else 700 %}
      {% if isSemiBold %}
      {% set googleFontUrl = 'https://fonts.googleapis.com/css2?family=' ~ googleFont ~ ':wght@500;600&display=swap' %}
      {% else %}
      {% set googleFontUrl = 'https://fonts.googleapis.com/css2?family=' ~ googleFont ~ ':wght@400;500;600;700;800&display=swap' %}
      {% endif %}
      :root {
        --cl-accent: {{ global.properties.theme_color }};
        --cl-accent-rgb: {{ global.properties.theme_color | hex_to_rgb }};
        --cl-background-primary: {{ global.properties.primary_background_color }};
        --cl-background-primary-rgb: {{ global.properties.primary_background_color | hex_to_rgb }};
        --cl-background-secondary: {{ global.properties.secondary_background_color }};
        --cl-background-secondary-rgb: {{ global.properties.secondary_background_color | hex_to_rgb }};
        --cl-border: {{ global.properties.primary_border_color }};
        --cl-border-rgb: {{ global.properties.primary_border_color | hex_to_rgb }};
        --bs-font-sans-serif: '{{ cssFont }}', sans-serif;
        --bs-body-font-family: var(--bs-font-sans-serif);
        --theme-font-weight: {{ 500 if isSemiBold else themeFontWeight }};
        --theme-heading-weight: {{ 600 if isSemiBold else themeHeadingWeight }};
        --produce-hero-size: 64px;
        --produce-hero-lh: 64px;
        --produce-hero-ls: -0.03em;
        --produce-hero-color: #0A0B10;
        --produce-section-size: 52px;
        --produce-section-lh: 62.4px;
        --produce-section-ls: -0.03em;
        --produce-section-color: #151621;
        --produce-card-title-size: 24px;
        --produce-card-title-lh: 28.8px;
        --produce-card-title-ls: -0.03em;
        --produce-card-title-color: #0A0B10;
        --produce-body-size: 16px;
        --produce-body-lh: 24px;
        --produce-body-ls: -0.3px;
        --produce-body-color: #626262;
        --produce-nav-size: 16px;
        --produce-nav-lh: 22.4px;
        --produce-nav-ls: -0.5px;
        --produce-nav-color: #626262;
        --produce-btn-size: 15px;
        --produce-btn-lh: 18px;
        --produce-btn-ls: -0.3px;
        --cl-snow: {{ (global.properties.snow_color if global.properties.snow_color else '#ffffff') | hex_to_rgb }};
      }

      html {
        font-family: var(--bs-font-sans-serif);
      }

      body,
      button,
      input,
      textarea,
      select,
      optgroup,
      .btn,
      .form-control,
      .form-select,
      .form-label,
      .modal,
      .dropdown-menu,
      .nav-link,
      .navbar,
      .card,
      .alert,
      .badge,
      .table,
      h1, h2, h3, h4, h5, h6,
      p, a, span, li, label, small, strong, em {
        font-family: var(--bs-font-sans-serif);
      }

      body {
        font-weight: var(--theme-font-weight);
        font-synthesis: none;
      }

      h1, h2, h3, h4, h5, h6,
      .h1, .h2, .h3, .h4, .h5, .h6 {
        font-weight: var(--theme-heading-weight);
        font-synthesis: none;
      }

      strong, b {
        font-weight: inherit;
      }

      .btn,
      .form-control,
      .form-select,
      .nav-link:not(.vl-nav-link),
      .navbar-brand {
        font-weight: var(--theme-font-weight);
      }

      .simple-navbar .vl-nav-link {
        font-weight: 500;
        font-synthesis: none;
      }

      .simple-navbar .ps-btn-ghost,
      .simple-navbar .ps-btn-primary {
        font-family: var(--bs-font-sans-serif);
        font-size: var(--produce-btn-size, 15px);
        line-height: var(--produce-btn-lh, 18px);
        letter-spacing: var(--produce-btn-ls, -0.3px);
        font-weight: 600;
        font-synthesis: none;
      }
    </style>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="{{ googleFontUrl }}" rel="stylesheet" id="theme-font">

    <link href="{{ 'pro.css' | assetUrl }}" rel="stylesheet"/>
    <link href="{{ 'custom.css' | assetUrl }}" rel="stylesheet"/>
    <link href="{{ 'produce-landing.css' | assetUrl }}" rel="stylesheet"/>
    <link href="{{ 'shop-pages.css' | assetUrl }}" rel="stylesheet"/>

    <style>
      .site-background-fixed {
        background-color: var(--cl-background-primary, #ffffff);
        position: relative;
        min-height: 100vh;
      }

      #page-loader {
        position: fixed;
        inset: 0;
        z-index: 99999;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--cl-background-primary, #ffffff);
        transition: opacity 500ms ease, visibility 500ms ease;
      }

      #page-loader.is-hidden {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }

      .loader-content {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 200px;
        height: 200px;
      }

      .loader-circle {
        position: absolute;
        width: 110px;
        height: 110px;
        border-radius: 50%;
        border: 3px solid rgba(27, 68, 254, 0.12);
        border-top: 3px solid #1B44FE;
        animation: spin 1.1s cubic-bezier(0.5, 0, 0.5, 1) infinite;
      }

      .loader-wordmark {
        font-family: var(--bs-font-sans-serif);
        font-weight: var(--theme-font-weight, 600);
        font-size: 1.05rem;
        letter-spacing: -0.02em;
        color: #1B44FE;
        animation: pulse-logo 1.8s ease-in-out infinite;
      }

      @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
      }

      @keyframes pulse-logo {
        0%, 100% { opacity: 0.55; }
        50% { opacity: 1; }
      }
    </style>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/choices.js@10.2.0/public/assets/styles/choices.min.css" rel="stylesheet" integrity="sha256-gS3HxgWFFFqEo0wQoALebu5XlWdYr3gqd4/Tk5wt8Ig=" crossorigin="anonymous" />
  </head>
  <body class="site-background-fixed">
    <div id="page-loader" aria-hidden="true">
      <div class="loader-content">
        <div class="loader-circle"></div>
        <span class="loader-wordmark">Velora</span>
      </div>
    </div>
    {% if shop.background_image_url %}
      <div class="bg-image" style="background-image: url({{ shop.background_image_url }});"></div>
    {% endif %}
    
    <div class="flex-wrapper" id="app" x-data="app">
      <div>
        <header class="vl-navbar-wrap">
          {% render_component "navbar" %}
        </header>
        {{ templateContent | safe }}
      </div>
      {% render_component "footer" %}
      {% render_snippet "customer-login-modal.njk" %}
    </div>

    <script>
      window.shopId = {{ shop.id | json }};
      window.apiBaseUrl = {{ '' | apiInternalUrl | json }};
      window.currencyRatesUsd = {{ currency_rates_usd | json }};
      window.defaultCurrency = {{ currency | json }};
      window.shopCustomer = {{ shop_customer | json }};
    </script>

    {% if isBuilder %}
      {% render_snippet "script-builder.njk" %}
    {% endif %}

    {% if altcha or altcha_shop_customer %}
      <script type="module">
        import altcha from 'https://cdn.jsdelivr.net/npm/altcha@1.2.0/+esm'
      </script>
    {% elif shop.recaptcha_key %}
      <script src="https://www.google.com/recaptcha/api.js?render={{ shop.recaptcha_key }}"></script>
    {% endif %}

    <script
      src="https://cdn.jsdelivr.net/npm/js-cookie@3.0.5/dist/js.cookie.min.js"
      integrity="sha256-WCzAhd2P6gRJF9Hv3oOOd+hFJi/QJbv+Azn4CGB8gfY="
      crossorigin="anonymous"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/choices.js@10.2.0/public/assets/scripts/choices.min.js"
      integrity="sha256-P+JgcxEeZtxwYS1+TAAuusKFM646SB8Oodk0TYu9zuo="
      crossorigin="anonymous"
    ></script>
    <script
      src="{{ 'script.js' | assetUrl }}"
      crossorigin="anonymous"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.3/dist/cdn.min.js"
      integrity="sha256-aJ9ROXjRHWn00zeU9ylsmlhqLlXeebtEfN28P0dPnwc="
      crossorigin="anonymous"
    ></script>
    <script 
      src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"
      crossorigin="anonymous"
    ></script>

    {% if global.properties.snow %}
      <div id="snow"></div>
      <script>snow({ count: 200 });</script>
    {% endif %}

    {% render_snippet "script-integrations.njk" %}

    <script>
      (function () {
        const loader = document.getElementById('page-loader');
        if (!loader) return;

        window.addEventListener('load', function () {
          loader.classList.add('is-hidden');
          window.setTimeout(function () {
            loader.remove();
          }, 400);
        });

        window.setTimeout(function () {
          if (!loader.classList.contains('is-hidden')) {
            loader.classList.add('is-hidden');
            window.setTimeout(function () {
              loader.remove();
            }, 400);
          }
        }, 6000);
      })();
    </script>

    <!-- ============ Velora motion layer (smooth scroll + reveal) ============ -->
    <script src="https://cdn.jsdelivr.net/npm/lenis@1.3.23/dist/lenis.min.js" crossorigin="anonymous"></script>
    <script>
      (function () {
        var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        /* ---------- Scroll reveal (IntersectionObserver) ---------- */
        function setupReveal() {
          var items = Array.prototype.slice.call(document.querySelectorAll('[data-reveal]'));
          if (!items.length) return;

          document.querySelectorAll('[data-reveal-group]').forEach(function (group) {
            var kids = group.querySelectorAll(':scope > [data-reveal], :scope [data-reveal-stagger]');
            kids.forEach(function (kid, i) {
              kid.style.setProperty('--reveal-delay', Math.min(i * 100, 560) + 'ms');
            });
          });

          if (reduceMotion || !('IntersectionObserver' in window)) {
            items.forEach(function (el) { el.classList.add('is-visible'); });
            return;
          }

          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1, rootMargin: '0px 0px -6% 0px' });

          items.forEach(function (el) { io.observe(el); });
        }

        /* ---------- Hero entrance + parallax ---------- */
        function setupHeroMotion() {
          var hero = document.querySelector('.vl-hero, .produce-hero');
          if (!hero || reduceMotion) return;

          hero.classList.add('is-loaded');
          var heroReveals = hero.querySelectorAll('[data-reveal]');
          heroReveals.forEach(function (el, i) {
            setTimeout(function () {
              el.classList.add('is-visible');
            }, 100 + i * 90);
          });
        }

        /* ---------- Lenis smooth scroll ---------- */
        function setupLenis() {
          if (reduceMotion || typeof Lenis === 'undefined') return null;
          var lenis = new Lenis({
            duration: 1.05,
            easing: function (t) { return Math.min(1, 1.001 - Math.pow(2, -10 * t)); },
            smoothWheel: true,
            wheelMultiplier: 1,
            touchMultiplier: 1.5,
            autoRaf: true,
            allowNestedScroll: true
          });
          window.__lenis = lenis;

          /* Pause Lenis while Bootstrap modals are open */
          document.addEventListener('show.bs.modal', function () { lenis.stop(); });
          document.addEventListener('hidden.bs.modal', function () { lenis.start(); });
          return lenis;
        }

        /* ---------- Smooth anchor navigation ---------- */
        function setupAnchors() {
          document.addEventListener('click', function (e) {
            var a = e.target.closest('a[href]');
            if (!a) return;
            var raw = a.getAttribute('href');
            if (!raw || raw.indexOf('#') === -1) return;
            var id = raw.substring(raw.indexOf('#') + 1);
            if (!id) return;
            var target = document.getElementById(id);
            if (!target) return; /* cross-page anchor → let it navigate */
            e.preventDefault();
            if (window.__lenis) {
              window.__lenis.scrollTo(target, { offset: -72 });
            } else {
              target.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth' });
            }
            var openNav = document.querySelector('.vl-nav-mobile.is-open');
            if (openNav) {
              openNav.classList.remove('is-open');
              var tgl = document.querySelector('.vl-nav-toggle');
              if (tgl) tgl.setAttribute('aria-expanded', 'false');
            }
            var openNavBs = document.querySelector('#mobileNav.show');
            if (openNavBs && window.bootstrap) {
              var c = window.bootstrap.Collapse.getInstance(openNavBs);
              if (c) c.hide();
            }
          });
        }

        /* ---------- Navbar elevation + scroll spy ---------- */
        function setupNavbarState() {
          var nav = document.querySelector('.simple-navbar');
          if (!nav) return;
          function onScroll() {
            if (window.scrollY > 12) nav.classList.add('is-scrolled');
            else nav.classList.remove('is-scrolled');
          }
          onScroll();
          window.addEventListener('scroll', onScroll, { passive: true });
        }

        function init() {
          setupLenis();
          setupHeroMotion();
          setupReveal();
          setupAnchors();
          setupNavbarState();
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>

{% if isBuilder %}
<!-- __SELLAUTH_LIVE_RELOAD__ -->
<script>
(function() {
  let lastTs = 0;

  async function check() {
    try {
      const res = await fetch('http://127.0.0.1:3456/__reload', {
        cache: 'no-store'
      });

      const data = await res.json();

      if (lastTs && data.ts !== lastTs) {
        window.location.reload();
      }

      lastTs = data.ts;
    } catch (e) {}

    setTimeout(check, 1000);
  }

  check();
})();
</script>
{% endif %}

</body>
</html>