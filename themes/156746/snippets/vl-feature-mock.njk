<div class="vl-flow-app" data-flow-mock="{{ mock }}">
  {% if mock == 'scripts' %}
  <div class="vl-flow-terminal">
    <div class="vl-flow-terminal-bar">
      <span class="vl-flow-terminal-dots"><i></i><i></i><i></i></span>
      <span>boost-bot · console</span>
    </div>
    <div class="vl-flow-terminal-body" data-flow-terminal></div>
  </div>

  {% elif mock == 'discord' %}
  <header class="vl-flow-chrome">
    <span class="vl-flow-dots"><i></i><i></i><i></i></span>
    <span class="vl-flow-url">velora.market/discord</span>
  </header>
  <div class="vl-flow-mock-stage" data-flow-discord-stage>
    <div class="vl-flow-mock-stage__body" data-flow-discord-cart>
      <div class="vl-flow-receipt">
        <div class="vl-flow-receipt-head">
          <span>Your cart</span>
          <em data-flow-cart-count>0 items</em>
        </div>
        <ul class="vl-flow-receipt-lines" data-flow-cart-list>
          <li class="vl-flow-cart-line" aria-hidden="true"></li>
          <li class="vl-flow-cart-line" aria-hidden="true"></li>
          <li class="vl-flow-cart-line" aria-hidden="true"></li>
        </ul>
        <div class="vl-flow-receipt-total" data-flow-cart-total-row>
          <span>Total</span>
          <strong data-flow-cart-total>€0.00</strong>
        </div>
      </div>
      <span class="vl-flow-cta is-primary" data-flow-target="checkout">Checkout</span>
    </div>
    <div class="vl-flow-discord-pay" data-flow-discord-pay aria-hidden="true">
      <span class="vl-flow-pay-eyebrow">Complete payment</span>
      <strong class="vl-flow-pay-amount" data-flow-pay-amount>€0.00</strong>
      <div class="vl-flow-qr" data-flow-qr>
        <div class="vl-flow-qr__frame">
          <svg class="vl-flow-qr__matrix" viewBox="0 0 29 29" aria-hidden="true">
            <rect width="29" height="29" fill="#fff"/>
            <g fill="#111">
              <rect x="1" y="1" width="7" height="7"/><rect x="2" y="2" width="5" height="5" fill="#fff"/><rect x="3" y="3" width="3" height="3"/>
              <rect x="21" y="1" width="7" height="7"/><rect x="22" y="2" width="5" height="5" fill="#fff"/><rect x="23" y="3" width="3" height="3"/>
              <rect x="1" y="21" width="7" height="7"/><rect x="2" y="22" width="5" height="5" fill="#fff"/><rect x="3" y="23" width="3" height="3"/>
              <rect x="9" y="0" width="1" height="1"/><rect x="11" y="0" width="1" height="1"/><rect x="13" y="0" width="1" height="1"/><rect x="15" y="0" width="1" height="1"/>
              <rect x="8" y="2" width="1" height="1"/><rect x="10" y="2" width="1" height="1"/><rect x="12" y="2" width="1" height="1"/><rect x="14" y="2" width="1" height="1"/><rect x="16" y="2" width="1" height="1"/>
              <rect x="9" y="4" width="2" height="1"/><rect x="12" y="4" width="1" height="1"/><rect x="14" y="4" width="2" height="1"/>
              <rect x="8" y="6" width="1" height="1"/><rect x="10" y="6" width="3" height="1"/><rect x="14" y="6" width="1" height="1"/><rect x="16" y="6" width="1" height="1"/>
              <rect x="0" y="9" width="1" height="1"/><rect x="2" y="9" width="1" height="1"/><rect x="4" y="9" width="1" height="1"/><rect x="6" y="9" width="1" height="1"/>
              <rect x="8" y="8" width="1" height="1"/><rect x="10" y="8" width="1" height="1"/><rect x="12" y="8" width="1" height="1"/><rect x="14" y="8" width="1" height="1"/><rect x="16" y="8" width="1" height="1"/><rect x="18" y="8" width="1" height="1"/>
              <rect x="9" y="10" width="3" height="1"/><rect x="13" y="10" width="2" height="1"/><rect x="16" y="10" width="1" height="1"/><rect x="20" y="10" width="1" height="1"/><rect x="22" y="10" width="2" height="1"/>
              <rect x="8" y="12" width="2" height="1"/><rect x="11" y="12" width="1" height="1"/><rect x="13" y="12" width="1" height="1"/><rect x="15" y="12" width="2" height="1"/><rect x="18" y="12" width="1" height="1"/><rect x="21" y="12" width="1" height="1"/><rect x="24" y="12" width="1" height="1"/>
              <rect x="10" y="14" width="1" height="1"/><rect x="12" y="14" width="2" height="1"/><rect x="15" y="14" width="1" height="1"/><rect x="17" y="14" width="2" height="1"/><rect x="20" y="14" width="1" height="1"/><rect x="23" y="14" width="2" height="1"/>
              <rect x="8" y="16" width="1" height="1"/><rect x="11" y="16" width="1" height="1"/><rect x="13" y="16" width="3" height="1"/><rect x="17" y="16" width="1" height="1"/><rect x="19" y="16" width="1" height="1"/><rect x="22" y="16" width="1" height="1"/><rect x="25" y="16" width="1" height="1"/>
              <rect x="9" y="18" width="2" height="1"/><rect x="12" y="18" width="1" height="1"/><rect x="14" y="18" width="1" height="1"/><rect x="16" y="18" width="2" height="1"/><rect x="20" y="18" width="2" height="1"/><rect x="24" y="18" width="1" height="1"/>
              <rect x="8" y="20" width="1" height="1"/><rect x="10" y="20" width="1" height="1"/><rect x="13" y="20" width="2" height="1"/><rect x="17" y="20" width="1" height="1"/><rect x="19" y="20" width="3" height="1"/><rect x="23" y="20" width="1" height="1"/>
              <rect x="9" y="22" width="1" height="1"/><rect x="11" y="22" width="2" height="1"/><rect x="14" y="22" width="1" height="1"/><rect x="16" y="22" width="1" height="1"/><rect x="18" y="22" width="2" height="1"/><rect x="21" y="22" width="1" height="1"/><rect x="24" y="22" width="2" height="1"/>
              <rect x="8" y="24" width="2" height="1"/><rect x="12" y="24" width="1" height="1"/><rect x="15" y="24" width="2" height="1"/><rect x="19" y="24" width="1" height="1"/><rect x="22" y="24" width="1" height="1"/><rect x="25" y="24" width="1" height="1"/>
              <rect x="10" y="26" width="1" height="1"/><rect x="13" y="26" width="3" height="1"/><rect x="17" y="26" width="2" height="1"/><rect x="21" y="26" width="1" height="1"/><rect x="24" y="26" width="2" height="1"/>
            </g>
          </svg>
          <span class="vl-flow-qr__fill" aria-hidden="true"></span>
          <span class="vl-flow-qr__scan-rail" aria-hidden="true">
            <span class="vl-flow-qr__scan"></span>
          </span>
          <span class="vl-flow-qr__corners" aria-hidden="true"></span>
        </div>
      </div>
      <span class="vl-flow-pay-hint">Scan with your phone · Crypto · PayPal</span>
      <span class="vl-flow-pay-status" data-flow-pay-status>Waiting for payment…</span>
    </div>
    <div class="vl-flow-mock-success" data-flow-discord-success aria-hidden="true">
      <span class="vl-flow-success-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </span>
      <strong class="vl-flow-success-title">Order confirmed</strong>
      <span class="vl-flow-success-sub" data-flow-success-sub>Instant delivery · €0.00</span>
    </div>
  </div>

  {% else %}
  <header class="vl-flow-checkout-head">
    <span>Subscriptions</span>
    <span class="vl-flow-secure">3 active</span>
  </header>
  <div class="vl-flow-meters">
    <div class="vl-flow-meter is-on">
      <div class="vl-flow-meter-top">
        <span>Streaming · 4K</span>
        <em>Active</em>
      </div>
      <span class="vl-flow-meter-bar" data-flow-meter-bar data-target="78" data-duration="2400"><i></i></span>
    </div>
    <div class="vl-flow-meter">
      <div class="vl-flow-meter-top">
        <span>VPN · 12 months</span>
        <em>Ready</em>
      </div>
      <span class="vl-flow-meter-bar" data-flow-meter-bar data-target="100" data-duration="1900"><i></i></span>
    </div>
    <div class="vl-flow-meter">
      <div class="vl-flow-meter-top">
        <span>Cloud credits</span>
        <em>€50 left</em>
      </div>
      <span class="vl-flow-meter-bar" data-flow-meter-bar data-target="45" data-duration="1700"><i></i></span>
    </div>
  </div>
  <span class="vl-flow-cta">Access in minutes</span>
  {% endif %}
</div>
