<section id="how-it-works" class="vl-section vl-steps-section component" data-scroll-section>
  <div class="container">
    <header class="vl-section-head vl-section-head--center" data-reveal>
      <h2 class="vl-section-title">
        <span class="vl-section-sans">Digital orders were always slow.</span>
        <span class="vl-section-serif">Until we made them instant.</span>
      </h2>
      <p class="vl-section-sub">Browse the catalog, pay securely, and receive your order automatically — no waiting, no manual delivery.</p>
    </header>

    <div class="vl-flow-steps" data-reveal-group>
      <article class="vl-flow-card" data-reveal>
        {% render_snippet "vl-flow-spot.njk" %}
        <div class="vl-flow-ui" aria-hidden="true">
          <div class="vl-flow-panel">
            <div class="vl-flow-app">
              <header class="vl-flow-chrome">
                <span class="vl-flow-dots"><i></i><i></i><i></i></span>
                <span class="vl-flow-url">velora.market/catalog</span>
              </header>
              <div class="vl-flow-search">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M20 20l-3-3"/></svg>
                <span>Search Boost Bot, token checker…</span>
              </div>
              <div class="vl-flow-products">
                <div class="vl-flow-product is-on">
                  <span class="vl-flow-product-thumb"></span>
                  <span class="vl-flow-product-meta">
                    <span class="vl-flow-product-name">Boost Bot</span>
                    <span class="vl-flow-product-price">€9.99</span>
                  </span>
                </div>
                <div class="vl-flow-product">
                  <span class="vl-flow-product-thumb"></span>
                  <span class="vl-flow-product-meta">
                    <span class="vl-flow-product-name">Token checker</span>
                    <span class="vl-flow-product-price">€4.99</span>
                  </span>
                </div>
              </div>
              <span class="vl-flow-cta">Add to cart · No account</span>
            </div>
          </div>
        </div>
        <div class="vl-flow-body">
          <span class="vl-flow-step">Step 1</span>
          <h3 class="vl-flow-title">Browse the full catalog in seconds</h3>
          <p class="vl-flow-text">Scripts, keys and licenses — on the web store or Discord shop. Add to cart without creating an account.</p>
        </div>
      </article>

      <article class="vl-flow-card" data-reveal>
        {% render_snippet "vl-flow-spot.njk" %}
        <div class="vl-flow-ui" aria-hidden="true">
          <div class="vl-flow-panel">
            <div class="vl-flow-app">
              <div class="vl-flow-form-head">
                <span>Checkout</span>
                <strong>€24.99</strong>
              </div>
              <div class="vl-flow-segment">
                <span class="is-on">Card</span>
                <span>Crypto</span>
                <span>PayPal</span>
              </div>
              <div class="vl-flow-fields">
                <span class="vl-flow-field"></span>
                <div class="vl-flow-fields-row">
                  <span class="vl-flow-field"></span>
                  <span class="vl-flow-field is-sm"></span>
                </div>
              </div>
              <span class="vl-flow-cta is-primary">Pay securely</span>
            </div>
          </div>
        </div>
        <div class="vl-flow-body">
          <span class="vl-flow-step">Step 2</span>
          <h3 class="vl-flow-title">Encrypted checkout in one click</h3>
          <p class="vl-flow-text">Pay with card, crypto, or PayPal. Every transaction is protected from checkout to confirmation.</p>
        </div>
      </article>

      <article class="vl-flow-card" data-reveal>
        {% render_snippet "vl-flow-spot.njk" %}
        <div class="vl-flow-ui" aria-hidden="true">
          <div class="vl-flow-panel">
            <div class="vl-flow-app">
              <div class="vl-flow-timeline">
                <div class="vl-flow-timeline-row is-done" data-reveal>
                  <span class="vl-flow-timeline-dot"></span>
                  <span>Payment confirmed</span>
                </div>
                <div class="vl-flow-timeline-row is-done" data-reveal>
                  <span class="vl-flow-timeline-dot"></span>
                  <span>Order processing</span>
                </div>
                <div class="vl-flow-timeline-row is-active" data-reveal>
                  <span class="vl-flow-timeline-dot"></span>
                  <span>Delivered · 0.4s</span>
                </div>
              </div>
              <div class="vl-flow-keycard">
                <span class="vl-flow-keycard-label">License key</span>
                <code>VMRK-8F2A-****-K9Q1</code>
                <span class="vl-flow-keycard-copy">Copy</span>
              </div>
              <div class="vl-flow-delivery-foot">
                <span class="vl-flow-status-dot" aria-hidden="true"></span>
                Automatic delivery after payment
              </div>
            </div>
          </div>
        </div>
        <div class="vl-flow-body">
          <span class="vl-flow-step">Step 3</span>
          <h3 class="vl-flow-title">Delivered instantly, every time</h3>
          <p class="vl-flow-text">Keys, licenses and access sent automatically the moment payment is confirmed — 24/7, no manual delivery.</p>
        </div>
      </article>
    </div>
  </div>
</section>
