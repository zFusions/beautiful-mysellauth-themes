{% set markSize = size | default(28) %}

{% set lockupClass = class | default('vl-brand-lockup') %}

{% set brandName = (name | default(shop.name)) | trim | replace('VeloraMarket', 'Velora Market') %}

{% set parts = brandName.split(' ') %}

{% set brandPrimary = parts[0] %}

{% set brandAccent = '' %}

{% if parts.length > 1 %}

  {% set brandAccent = brandName.slice(brandPrimary.length) %}

{% endif %}

<span class="{{ lockupClass }}">

  {% if show_mark | default(true) %}

    {% render_snippet "velora-brand-mark.njk", size=markSize, class='vl-brand-lockup__mark', eager=eager | default(false) %}

  {% endif %}

  <span class="vl-brand-wordmark">

    <span class="vl-brand-wordmark__primary">{{ brandPrimary }}</span>{% if brandAccent %}<span class="vl-brand-wordmark__accent">{{ brandAccent }}</span>{% endif %}

  </span>

</span>

