<div class="vl-hero-mock">
  <div class="vl-hero-mock-stage">
    <div class="vl-hero-mock-glow" aria-hidden="true">
      <div class="vl-hero-mock-disc vl-hero-mock-disc__haze"></div>
      <div class="vl-hero-mock-disc vl-hero-mock-disc__core"></div>
    </div>
    <div class="vl-hero-dashboard vl-boost-panel" data-boost-panel aria-hidden="true">
      <div class="vl-boost-layout">
        <header class="vl-boost-chrome" aria-hidden="true">
          <span class="vl-boost-chrome-dots"><i></i><i></i><i></i></span>
          <span class="vl-boost-chrome-title">boost-bot · v2.4.1</span>
          <span class="vl-boost-chrome-live">Live</span>
        </header>
        <aside class="vl-boost-side">
          <div class="vl-boost-side-logo" title="Boost Bot"></div>
          <nav class="vl-boost-side-nav" aria-hidden="true">
            <span class="is-active" data-boost-nav="console" title="Console"></span>
            <span data-boost-nav="tokens" title="Tokens"></span>
            <span data-boost-nav="history" title="History"></span>
            <span data-boost-nav="settings" title="Settings"></span>
          </nav>
        </aside>

        <div class="vl-boost-body">
          <div class="vl-boost-top">
            <div class="vl-boost-top-meta">
              <h3 class="vl-boost-top-title">Boost Bot v2</h3>
              <span class="vl-boost-top-ver">console</span>
            </div>
            <span class="vl-boost-status" data-boost-status>
              <span class="vl-boost-status-dot"></span>
              <span data-boost-status-label>Running</span>
            </span>
          </div>

          <div class="vl-boost-task" data-boost-task hidden aria-hidden="true"></div>

          <div class="vl-boost-metrics" data-boost-metrics>
            <div class="vl-boost-metric">
              <span class="vl-boost-metric-label">Boosts</span>
              <span class="vl-boost-metric-val" data-boost-metric="0">—</span>
            </div>
            <div class="vl-boost-metric">
              <span class="vl-boost-metric-label">Tokens</span>
              <span class="vl-boost-metric-val" data-boost-metric="1">—</span>
            </div>
            <div class="vl-boost-metric">
              <span class="vl-boost-metric-label">Invite</span>
              <span class="vl-boost-metric-val is-truncate" data-boost-metric="2">velora-market</span>
            </div>
          </div>

          <div class="vl-boost-terminal" data-boost-terminal>
            <div class="vl-boost-terminal-bar">
              <span class="vl-boost-terminal-dots"><i></i><i></i><i></i></span>
              <span data-boost-tab>boost-bot · console</span>
              <span class="vl-boost-terminal-ping" data-boost-ping>—</span>
            </div>
            <div class="vl-boost-terminal-body" data-boost-logs></div>
            <div class="vl-boost-widgets" data-boost-widgets hidden></div>
          </div>

          <div class="vl-boost-progress" data-boost-progress>
            <div class="vl-boost-progress-head">
              <span data-boost-progress-label>Boost progress</span>
              <span class="vl-boost-progress-count" data-boost-progress-count>0/0</span>
            </div>
            <div class="vl-boost-progress-track">
              <span class="vl-boost-progress-fill" data-boost-progress-fill></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
