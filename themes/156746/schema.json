                                "paypal",
                                "shield",
                                "lock",
                                "zap"
                            ],
                            "default": "zap"
                        }
                    },
                    "default": [
                        { "label": "Stripe", "icon": "stripe" },
                        { "label": "PayPal", "icon": "paypal" },
                        { "label": "Encrypted checkout", "icon": "shield" },
                        { "label": "SSL secured", "icon": "lock" },
                        { "label": "Instant delivery", "icon": "zap" }
