{
    "global": {
        "properties": {
            "theme_color": {
                "label": "Theme Color",
                "type": "color"
            },
            "primary_background_color": {
                "label": "Primary Background Color",
                "type": "color"
            },
            "secondary_background_color": {
                "label": "Secondary Background Color",
                "type": "color"
            },
            "primary_border_color": {
                "label": "Primary Border Color",
                "type": "color"
            },
            "font": {
                "label": "Font",
                "type": "font",
                "default": "Poppins"
            },
            "snow": {
                "label": "Snow Effect",
                "type": "toggle",
                "default": false
            },
            "snow_color": {
                "label": "Snowflake Color",
                "type": "color",
                "default": "#ffffff"
            }
        }
