                    "label": "Secondary button text",
                    "type": "text",
                    "default": "Contact support"
                },
                "secondary_cta": {
                    "label": "Secondary button link",
                    "help": "Leave empty to use shop Discord URL when available.",
                    "type": "text",
                    "default": ""
                }
