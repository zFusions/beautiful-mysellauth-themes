    "components": {
        "announcement": {
            "label": "Announcement",
            "global": true,
            "order": 0,
            "properties": {
                "text": {
                    "label": "Text",
                    "type": "text"
                },
                "link": {
                    "label": "Link",
                    "type": "text"
                },
                "link_text": {
                    "label": "Link Text",
                    "type": "text"
                }
            }
        },
        "navbar": {
            "label": "Navbar",
            "global": true,
            "order": 1,
            "properties": {
              "show_shop_name": {
                "label": "Show Shop Name",
                "help": "Defined in Shop Settings",
                "type": "toggle",
                "default": true
              },
              "show_logo": {
                "label": "Show Logo",
                "help": "Defined in Shop Settings",
                "type": "toggle",
                "default": true
              },
              "hide_currency_selector": {
                "label": "Hide Currency Selector",
                "type": "toggle",
                "default": false
              },
              "hide_customer_dashboard": {
                "label": "Hide Customer Dashboard",
                "type": "toggle",
                "default": false
              },
              "hide_cart": {
                "label": "Hide Cart",
                "type": "toggle",
                "default": false
              },
              "left_links": {
                "label": "Left Links",
                "type": "list",
                "maxItems": 10,
                "properties": {
                  "text": {
                    "label": "Text",
                    "type": "text",
                    "default": "New Link"
                  },
                  "link": {
                    "label": "Link",
                    "type": "text",
                    "default": "#"
                  },
                  "icon": {
                    "label": "Icon",
                    "type": "icon",
                    "default": "fas fa-home"
                  },
                  "new_tab": {
                    "label": "Open in New Tab",
                    "type": "toggle",
                    "default": false
                  },
                  "shape": {
                    "label": "Shape",
                    "type": "select",
                    "options": [
                      "regular",
                      "button"
                    ],
                    "default": "regular"
                  }
                },
                "default": [
                  {
                    "text": "Home",
                    "link": "/",
                    "icon": "fas fa-home",
                    "new_tab": false
                  },
                  {
                    "text": "Feedback",
                    "link": "/feedback",
                    "icon": "fas fa-star",
                    "new_tab": false
                  },
                  {
                    "text": "Terms of Service",
                    "link": "/tos",
                    "icon": "fas fa-file-contract",
                    "new_tab": false
                  }
                ]
              },
              "right_links": {
                "label": "Right Links",
                "type": "list",
                "maxItems": 10,
                "properties": {
                  "text": {
                    "label": "Text",
                    "type": "text",
                    "default": "New Link"
                  },
                  "link": {
                    "label": "Link",
                    "type": "text",
                    "default": "#"
                  },
                  "new_tab": {
                    "label": "Open in New Tab",
                    "type": "toggle",
                    "default": false
                  },
                  "shape": {
                    "label": "Shape",
                    "type": "select",
                    "options": [
                      "regular",
                      "button"
                    ],
                    "default": "regular"
                  }
                },
                "default": [
                  {
                    "text": "Products",
                    "link": "/#products",
                    "new_tab": false
                  }
                ]
              }
            }
        },
        "hero": {
            "label": "Hero",
            "templates": ["shop"],
            "properties": {
                "title": {
                    "label": "Title",
                    "type": "text",
                    "default": "Welcome to our shop!"
                },
                "subtitle": {
                    "label": "Subtitle",
                    "type": "text"
                },
                "badge_text": {
                    "label": "Badge Text",
                    "type": "text",
                    "default": "New stock arrived 🚚"
                  },
                "cta_text": {
                    "label": "1.Button Text",
                    "type": "text",
                    "default": "Explore Products"
                },
                "cta": {
                    "label": "1.Button Link",
                    "type": "text",
                    "default": "/#products"
                },
                "cta_text_2": {
                    "label": "2.Button Text",
                    "type": "text"                },
                "cta_2": {
                    "label": "2.Button Link",
                    "type": "text"                },
                "show_searchbar": {
                    "label": "Show Searchbar",
                    "type": "toggle",
                    "default": true
                },
                "show_support": {
                    "label": "Show Support 24/7",
                    "type": "toggle",
                    "default": true
                },
                "show_feedback_rating": {
                    "label": "Show Feedback Rating",
                    "type": "toggle",
                    "default": true
                },
                "show_products_sold": {
                    "label": "Show Products Sold",
                    "type": "toggle",
                    "default": true
                },
                "show_total_customers": {
                    "label": "Show Total Customers",
                    "type": "toggle",
                    "default": true
                },
                "alignment": {
                    "label": "Alignment",
                    "type": "select",
                    "options": [
                        "left",
                        "center",
                        "right"
                    ],
                    "default": "center"
                },
                "height": {
                    "label": "Height",
                    "type": "select",
                    "options": [
                        "short",
                        "medium",
                        "tall"
                    ],
                    "default": "tall"
                },
                "background_image": {
                    "label": "Background Image",
                    "type": "image"
                },
                "side_image": {
                    "label": "Side Image",
                    "type": "image",
                    "maxImages": 1
                },
                "show_hero_mock": {
                    "label": "Show Hero Dashboard Mock",
                    "help": "Decorative demo panel below the hero. Disable for a text-only hero when reselling the theme.",
                    "type": "toggle",
                    "default": true
                }
            }
        },
        "how-it-works": {
            "label": "How It Works",
            "multiple": true,
            "properties": {
                "title_sans": {
                    "label": "Title (sans)",
                    "type": "text",
                    "default": "Digital orders were always slow."
                },
                "title_serif": {
                    "label": "Title (serif accent)",
                    "type": "text",
                    "default": "Until we made them instant."
                },
                "subtitle": {
                    "label": "Subtitle",
                    "type": "textarea",
                    "default": "Browse the catalog, pay securely, and receive your order automatically — no waiting, no manual delivery."
                },
                "show_mock_ui": {
                    "label": "Show Step Demo Panels",
                    "help": "Animated checkout/delivery demos. Disable to show step copy only — recommended for some resellers.",
                    "type": "toggle",
                    "default": true
                },
                "steps": {
                    "label": "Steps",
                    "type": "list",
                    "maxItems": 3,
                    "properties": {
                        "step_label": {
                            "label": "Step label",
                            "type": "text",
                            "default": "Step 1"
                        },
                        "title": {
                            "label": "Title",
                            "type": "text",
                            "default": "Step title"
                        },
                        "text": {
                            "label": "Description",
                            "type": "textarea",
                            "default": "Step description."
                        }
                    },
                    "default": [
                        {
                            "step_label": "Step 1",
                            "title": "Browse the full catalog in seconds",
                            "text": "Scripts, keys and licenses — on the web store or Discord shop. Add to cart without creating an account."
                        },
                        {
                            "step_label": "Step 2",
                            "title": "Encrypted checkout in one click",
                            "text": "Pay with card, crypto, or PayPal. Every transaction is protected from checkout to confirmation."
                        },
                        {
                            "step_label": "Step 3",
                            "title": "Delivered instantly, every time",
                            "text": "Keys, licenses and access sent automatically the moment payment is confirmed — 24/7, no manual delivery."
                        }
                    ]
                }
            }
        },
        "final-cta": {
            "label": "Final CTA",
            "multiple": true,
            "properties": {
                "title": {
                    "label": "Title",
                    "type": "text",
                    "default": "Get your order in seconds"
                },
                "subtitle": {
                    "label": "Subtitle",
                    "type": "textarea",
                    "default": "Scripts, software, licenses and more — web store or Discord shop. Secure checkout, automatic delivery."
