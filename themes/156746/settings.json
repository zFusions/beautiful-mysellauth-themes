                    "properties": {
                        "title_sans": "Digital orders were always slow.",
                        "title_serif": "Until we made them instant.",
                        "subtitle": "Browse the catalog, pay securely, and receive your order automatically — no waiting, no manual delivery.",
                        "show_mock_ui": true,
                        "steps": [
                            {
                                "step_label": "Step 1",
                                "title": "Browse the full catalog in seconds",
                                "text": "Scripts, keys and licenses — on the web store or Discord shop. Add to cart without creating an account."
                            },
                            {
                                "step_label": "Step 2",
                                "title": "Encrypted checkout in one click",
                                "text": "Pay with card, crypto, or PayPal. Every transaction is protected from checkout to confirmation."
                            },
                            {
                                "step_label": "Step 3",
                                "title": "Delivered instantly, every time",
                                "text": "Keys, licenses and access sent automatically the moment payment is confirmed — 24/7, no manual delivery."
                            }
                        ]
                    }
                },
                "final-cta": {
                    "type": "final-cta",
                    "properties": {
                        "title": "Get your order in seconds",
                        "subtitle": "Pay on the web store or Discord shop. Keys and access land in your inbox seconds after checkout.",
