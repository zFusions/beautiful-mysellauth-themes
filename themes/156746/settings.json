        "terms": {
            "layout": "master",
            "components": {
                "terms-page": {
                    "type": "terms-page",
                    "properties": {
                        "title_prefix": "Terms of",
                        "title_accent": "Service",
                        "subtitle": "Purchasing or using our products means you accept the conditions below.",
                        "highlights": [
                            {
                                "title": "No refunds",
                                "text": "All sales are final unless we say it clearly.",
                                "icon": "x"
                            },
                            {
                                "title": "Product-based warranty",
                                "text": "Each product has its own support window.",
                                "icon": "shield"
                            },
                            {
                                "title": "Proof needed",
                                "text": "To replace something, we need evidence.",
                                "icon": "info"
                            }
                        ],
                        "sections": [
                            {
                                "title": "1) Refunds",
                                "intro": "We do not offer refunds on digital products. Please read carefully before purchasing.",
                                "items": [
                                    { "text": "All sales are final.", "type": "x" },
                                    { "text": "Chargebacks or payment disputes may result in a permanent ban.", "type": "x" },
                                    { "text": "Replacements are only offered when a product fails to deliver as described.", "type": "check" },
                                    { "text": "Contact support with your order ID before opening a dispute.", "type": "info" }
                                ]
                            },
                            {
                                "title": "2) Warranty & support",
                                "intro": "Support windows vary by product. Check the product page for specific coverage.",
                                "items": [
                                    { "text": "Instant delivery products — support within 24 hours of purchase.", "type": "check" },
                                    { "text": "Subscription-based products — warranty until expiry date shown at checkout.", "type": "dot" },
                                    { "text": "Boost / upgrade services — warranty covers the full purchased period.", "type": "dot" },
                                    { "text": "Abuse, sharing, or reselling voids all warranty.", "type": "x" }
                                ]
                            },
                            {
                                "title": "3) Replacements",
                                "intro": "If something goes wrong, we will help — but we need proof.",
                                "items": [
                                    { "text": "Provide your order ID and a clear description of the issue.", "type": "check" },
                                    { "text": "Screenshots or screen recordings may be required.", "type": "info" },
                                    { "text": "False claims or repeated abuse will result in account termination.", "type": "x" },
                                    { "text": "Replacements are issued at our discretion within the warranty window.", "type": "check" }
                                ]
                            }
                        ]
                    }
                }
            },
            "components_order": [
                "terms-page"
            ]
        },
