            "layout": "master",
            "components": {
                "privacy-policy-page": {
                    "type": "privacy-policy-page",
                    "properties": {
                        "title_prefix": "Privacy",
                        "title_accent": "Policy",
                        "subtitle": "How we collect, use and protect your information.",
                        "highlights": [
                            { "title": "Minimal data", "text": "We only collect what's needed to deliver your order.", "icon": "check" },
                            { "title": "Secure checkout", "text": "Payments are encrypted via trusted providers.", "icon": "shield" },
                            { "title": "Never sold", "text": "We do not sell your personal data to third parties.", "icon": "info" }
                        ],
                        "sections": [
                            {
                                "title": "1) Data we collect",
                                "intro": "We collect only the information required to process orders and provide support.",
                                "items": [
                                    { "text": "Email address for delivery and order updates.", "type": "dot" },
                                    { "text": "Payment data handled by our payment processor — never stored on our servers.", "type": "check" },
                                    { "text": "IP address and browser data for fraud prevention.", "type": "info" }
                                ]
                            },
                            {
                                "title": "2) How we use your data",
                                "intro": "Your data is used solely to operate the store and support you.",
                                "items": [
                                    { "text": "Deliver digital products instantly after payment.", "type": "check" },
                                    { "text": "Send order confirmations and support replies.", "type": "check" },
                                    { "text": "We do not send marketing emails without consent.", "type": "x" }
                                ]
                            },
                            {
                                "title": "3) Your rights",
                                "intro": "You can request access, correction or deletion of your data.",
                                "items": [
                                    { "text": "Contact support to request a copy of your data.", "type": "check" },
                                    { "text": "Account deletion available on request.", "type": "info" },
                                    { "text": "We respond to privacy requests within 30 days.", "type": "dot" }
                                ]
                            }
                        ]
                    }
                }
            },
            "components_order": [
                "privacy-policy-page"
            ]
        },
        "refund-policy": {
            "layout": "master",
            "components": {
                "refund-policy-page": {
                    "type": "refund-policy-page",
                    "properties": {
                        "title_prefix": "Refund",
                        "title_accent": "Policy",
                        "subtitle": "Our refund and replacement rules for digital products.",
                        "highlights": [
                            { "title": "All sales final", "text": "Digital products cannot be returned once delivered.", "icon": "x" },
                            { "title": "Replacements available", "text": "Faulty products may qualify for a free replacement.", "icon": "check" },
                            { "title": "Contact first", "text": "Reach support before opening a payment dispute.", "icon": "info" }
                        ],
                        "sections": [
                            {
                                "title": "1) Refund eligibility",
                                "intro": "Due to the nature of digital goods, refunds are generally not available.",
                                "items": [
                                    { "text": "No refunds after the product has been delivered.", "type": "x" },
                                    { "text": "Accidental purchases are not eligible for refunds.", "type": "x" },
                                    { "text": "Duplicate charges will be refunded after verification.", "type": "check" }
                                ]
                            },
                            {
                                "title": "2) Replacements",
                                "intro": "If a product doesn't work as described, we may offer a replacement.",
                                "items": [
                                    { "text": "Report the issue within the product warranty window.", "type": "check" },
                                    { "text": "Provide your order ID and proof of the issue.", "type": "info" },
                                    { "text": "One replacement per order unless otherwise stated.", "type": "dot" }
                                ]
                            },
                            {
                                "title": "3) Chargebacks",
                                "intro": "Opening a dispute without contacting us first may result in a ban.",
                                "items": [
                                    { "text": "Contact support before initiating a chargeback.", "type": "check" },
                                    { "text": "Fraudulent chargebacks lead to permanent account suspension.", "type": "x" }
                                ]
                            }
                        ]
