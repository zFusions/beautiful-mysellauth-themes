                "faq": {
                    "type": "faq",
                    "properties": {
                        "aside_eyebrow": "Support",
                        "aside_title": "Got questions?<br>We've got answers.",
                        "aside_subtitle": "Everything you need to know before you buy. Can't find it? We're one message away.",
                        "help_title": "Still have questions?",
                        "help_text": "Our team replies around the clock on Discord.",
                        "help_button_text": "Chat with us",
                        "items": [
                            {
                                "question": "How do I receive my product after purchase?",
                                "answer": "All our products are delivered instantly. After payment, you receive your key, license or access on the site, by email, or in your account. If you need help, join our __DISCORD__."
                            },
                            {
                                "question": "What are the official contact methods?",
                                "answer": "We are mainly available on __DISCORD__ and __TELEGRAM__. Beware of imposters — only use the official links shown here and in our site footer."
                            },
                            {
                                "question": "Are the services guaranteed?",
                                "answer": "Yes, we offer warranties on our products. Specific warranty details and durations are mentioned in the description of each product. Our 24\/7 support is also available for any assistance."
                            },
                            {
                                "question": "Do you offer discounts for bulk orders?",
                                "answer": "Absolutely! Contact us on __TELEGRAM__ or open a ticket on __DISCORD__ to discuss bulk pricing for your large orders."
                            },
                            {
                                "question": "How can I contact support if I have a problem?",
                                "answer": "Our dedicated support team is available 24\/7. You can reach us by opening a ticket on our __DISCORD__ server or messaging us on __TELEGRAM__. We guarantee a response to all inquiries."
                            },
                            {
                                "question": "How fast is delivery?",
                                "answer": "Digital products are delivered automatically within seconds after payment is confirmed — 24\/7, no manual processing. Check your email and customer dashboard for order details."
                            },
                            {
                                "question": "What is your refund policy?",
                                "answer": "Refund eligibility depends on the product type and whether digital goods have been delivered or used. Read our Refund Policy page, or contact support on __DISCORD__ before opening a dispute."
                            },
                            {
                                "question": "Can I buy from your Discord shop?",
                                "answer": "Yes — the same catalog is available on our web store and Discord shop. Browse, pay securely, and receive automatic delivery on both channels."
                            }
                        ]
                    }
                },
