<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    {% set isLanding = templateName == 'shop' %}
    {% set isProduct = templateName == 'product' %}
    {% set hideCurrency = global.components.navbar.hide_currency_selector | default(false) %}

    {% render_snippet "meta-tags.njk" %}

    {% if isLanding %}
    <link rel="preload" href="{{ 'velora-mark-128.png' | assetUrl }}" as="image" type="image/png">
    {% endif %}

    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com">

    <script>document.documentElement.classList.add('vl-js-motion');</script>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />

    <style id="theme-styles">
      :root {
        --cl-accent: {{ global.properties.theme_color }};
        --cl-accent-rgb: {{ global.properties.theme_color | hex_to_rgb }};
        --cl-background-primary: {{ global.properties.primary_background_color }};
        --cl-background-primary-rgb: {{ global.properties.primary_background_color | hex_to_rgb }};
        --cl-background-secondary: {{ global.properties.secondary_background_color }};
        --cl-background-secondary-rgb: {{ global.properties.secondary_background_color | hex_to_rgb }};
        --cl-border: {{ global.properties.primary_border_color }};
        --cl-border-rgb: {{ global.properties.primary_border_color | hex_to_rgb }};
        --bs-font-sans-serif: Arial, Helvetica, sans-serif;
        --bs-body-font-family: var(--bs-font-sans-serif);
        --font-display: Arial, Helvetica, sans-serif;
        --font-body: Arial, Helvetica, sans-serif;
        --font-serif: 'Playfair Display', Georgia, 'Times New Roman', serif;
        --theme-font-weight: 400;
        --theme-heading-weight: 400;
        --cl-snow: {{ (global.properties.snow_color if global.properties.snow_color else '#ffffff') | hex_to_rgb }};
      }

      html { font-family: var(--bs-font-sans-serif); }

      body,
      button,
      input,
      textarea,
      select,
      .btn,
      .form-control,
      .form-select,
      h1, h2, h3, h4, h5, h6,
      p, a, span, li, label {
        font-family: var(--bs-font-sans-serif);
        font-synthesis: none;
      }

      body { font-weight: var(--theme-font-weight); }

      h1, h2, h3, h4, h5, h6 {
        font-weight: var(--theme-heading-weight);
      }
    </style>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Montserrat:wght@500;600;700&family=Playfair+Display:wght@400;600&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
      id="theme-font"
    >
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Montserrat:wght@500;600;700&family=Playfair+Display:wght@400;600&display=swap" rel="stylesheet">
    </noscript>

    <link href="{{ 'pro.css' | assetUrl }}" rel="stylesheet"/>
    <link href="{{ 'custom.css' | assetUrl }}" rel="stylesheet"/>
    <link href="{{ 'velora.css' | assetUrl }}" rel="stylesheet"/>

    <link href="{{ 'shop-pages.css' | assetUrl }}" rel="stylesheet"/>
    {% if isProduct %}
    <link href="{{ 'shop-pdp.css' | assetUrl }}" rel="stylesheet"/>
    {% endif %}
    <link rel="preload" href="{{ 'shop-components.css' | assetUrl }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link href="{{ 'shop-components.css' | assetUrl }}" rel="stylesheet"></noscript>

    <style>
      .site-background-fixed {
        position: relative;
        min-height: 100vh;
      }

      #page-loader {
        position: fixed;
        inset: 0;
        z-index: 99999;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--cl-background-primary, #030303);
        transition: opacity 500ms ease, visibility 500ms ease;
      }

      #page-loader.is-hidden {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }

      #page-loader.page-loader--fast .loader-circle {
        width: 72px;
        height: 72px;
        border-width: 2px;
      }

      #page-loader.page-loader--fast .loader-content {
        width: 120px;
        height: 120px;
      }

      .loader-mark {
        position: relative;
        z-index: 1;
        width: 56px;
        height: 56px;
        object-fit: contain;
        animation: pulse-logo 1.8s ease-in-out infinite;
      }

      #page-loader.page-loader--fast .loader-mark {
        width: 40px;
        height: 40px;
      }

      html.vl-page-exit #app {
        opacity: 0;
        filter: blur(10px);
        transform: scale(0.985);
        transition: opacity 200ms ease, filter 200ms ease, transform 200ms ease;
      }

      .loader-content {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 200px;
        height: 200px;
      }

      .loader-circle {
        position: absolute;
        width: 110px;
        height: 110px;
        border-radius: 50%;
        border: 3px solid rgba(249, 153, 38, 0.15);
        border-top: 3px solid #F99926;
        animation: spin 1.1s cubic-bezier(0.5, 0, 0.5, 1) infinite;
      }

      .loader-wordmark {
        display: none;
      }

      @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
      }

      @keyframes pulse-logo {
        0%, 100% { opacity: 0.55; }
        50% { opacity: 1; }
      }
    </style>

    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet"></noscript>
    {% if not hideCurrency %}
    <link rel="preload" href="https://cdn.jsdelivr.net/npm/choices.js@10.2.0/public/assets/styles/choices.min.css" as="style" integrity="sha256-gS3HxgWFFFqEo0wQoALebu5XlWdYr3gqd4/Tk5wt8Ig=" crossorigin="anonymous" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link href="https://cdn.jsdelivr.net/npm/choices.js@10.2.0/public/assets/styles/choices.min.css" rel="stylesheet" integrity="sha256-gS3HxgWFFFqEo0wQoALebu5XlWdYr3gqd4/Tk5wt8Ig=" crossorigin="anonymous"></noscript>
    {% endif %}
  </head>
  <body class="site-background-fixed velora-home-page{% if isLanding %} velora-landing-page{% else %} velora-inner-page{% endif %}">
    <div id="page-loader" class="{{ 'page-loader--fast' if not isLanding else '' }}" aria-hidden="true">
      <div class="loader-content">
        <div class="loader-circle"></div>
        <img
          class="loader-mark"
          src="{{ 'velora-mark-512.png' | assetUrl }}"
          alt=""
          width="56"
          height="56"
          decoding="async"
        />
        <span class="loader-wordmark" aria-hidden="true">Velora</span>
      </div>
    </div>

    <div class="flex-wrapper" id="app" x-data="app">
      <div>
        <header class="vl-navbar-wrap">
          {% render_component "navbar" %}
        </header>
        <main class="vl-page-content">
          {{ templateContent | safe }}
        </main>
      </div>
      {% render_component "footer" %}
      {% render_snippet "customer-login-modal.njk" %}
    </div>

    <script>
      window.shopId = {{ shop.id | json }};
      window.apiBaseUrl = {{ '' | apiInternalUrl | json }};
      window.currencyRatesUsd = {{ currency_rates_usd | json }};
      window.defaultCurrency = {{ currency | json }};
      window.shopCustomer = {{ shop_customer | json }};
    </script>

    {% if isBuilder %}
      {% render_snippet "script-builder.njk" %}
    {% endif %}

    {% if altcha or altcha_shop_customer %}
      <script type="module">
        import altcha from 'https://cdn.jsdelivr.net/npm/altcha@1.2.0/+esm'
      </script>
    {% elif shop.recaptcha_key %}
      <script src="https://www.google.com/recaptcha/api.js?render={{ shop.recaptcha_key }}"></script>
    {% endif %}

    <script
      defer
      src="https://cdn.jsdelivr.net/npm/js-cookie@3.0.5/dist/js.cookie.min.js"
      integrity="sha256-WCzAhd2P6gRJF9Hv3oOOd+hFJi/QJbv+Azn4CGB8gfY="
      crossorigin="anonymous"
    ></script>
    {% if not hideCurrency %}
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/choices.js@10.2.0/public/assets/scripts/choices.min.js"
      integrity="sha256-P+JgcxEeZtxwYS1+TAAuusKFM646SB8Oodk0TYu9zuo="
      crossorigin="anonymous"
    ></script>
    {% endif %}
    <script defer src="{{ 'script.js' | assetUrl }}"></script>
    {% if isLanding %}
    <script defer src="{{ 'velora-boost-mock.js' | assetUrl }}"></script>
    <script defer src="{{ 'velora-flow-mock.js' | assetUrl }}"></script>
    <script defer src="{{ 'velora-steps-mock.js' | assetUrl }}"></script>
    {% endif %}
    <script defer src="{{ 'lenis.min.js' | assetUrl }}"></script>
    <script defer src="{{ 'velora-reveal.js' | assetUrl }}"></script>
    <script defer src="{{ 'velora-motion.js' | assetUrl }}"></script>
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.3/dist/cdn.min.js"
      integrity="sha256-aJ9ROXjRHWn00zeU9ylsmlhqLlXeebtEfN28P0dPnwc="
      crossorigin="anonymous"
    ></script>

    {% if global.properties.snow %}
      <div id="snow"></div>
      <script defer>snow({ count: 200 });</script>
    {% endif %}

    {% render_snippet "script-integrations.njk" %}

    <script defer src="{{ 'velora-loader.js' | assetUrl }}"></script>

{% if isBuilder %}
<!-- __SELLAUTH_LIVE_RELOAD__ -->
<script>
(function() {
  let lastTs = 0;
  async function check() {
    try {
      const res = await fetch('http://127.0.0.1:3456/__reload', { cache: 'no-store' });
      const data = await res.json();
      if (lastTs && data.ts !== lastTs) window.location.reload();
      lastTs = data.ts;
    } catch (e) {}
    setTimeout(check, 1000);
  }
  check();
})();
</script>
{% endif %}

  </body>
</html>