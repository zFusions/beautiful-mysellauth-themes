<div class="component vl-premium-page vl-custom-page" data-component-id="{{ componentId }}">
  <section class="vl-legal-section vl-terms-section" aria-labelledby="vl-custom-page-title">
    <div class="vl-legal-shell vl-terms-shell">
      <a href="{{ '/' | shopUrl }}" class="vl-page-back vl-legal-back" data-reveal>← Back to store</a>
      <header class="vl-legal-hero vl-terms-hero" data-reveal>
        <h1 id="vl-custom-page-title" class="vl-legal-title vl-terms-title">{{ name }}</h1>
      </header>
    </div>
  </section>
</div>

<div class="components vl-custom-page-body">
  {% for componentId in components_order %}
    {% render_component componentId %}
  {% endfor %}
</div>
