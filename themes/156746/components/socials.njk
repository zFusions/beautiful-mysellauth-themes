{% if shop.discord_url or shop.telegram_url or shop.instagram_url or shop.tiktok_url or shop.youtube_url %}
<section class="discord-cta vl-socials-section vl-builder-section component" data-component-id="{{ componentId }}">
  <div class="container">
    <div class="discord-cta-box d-flex justify-content-between align-items-center">
      
      <div class="social-left d-flex align-items-center gap-3">
        <img src="{{ properties.image | imageUrl }}" alt="Icon" class="social-main-icon" />
        <div>
          {% if properties.title %}
            <h2 class="discord-cta-title">{{ properties.title | renderString }}</h2>
          {% endif %}
          {% if properties.subtitle %}
            <p class="discord-cta-text">{{ properties.subtitle | renderString }}</p>
          {% endif %}
        </div>
      </div>

      <div class="social-icons d-flex gap-3">
        {% if shop.discord_url %}
        <a href="{{ shop.discord_url }}" target="_blank" class="social-icon discord" title="Discord">
