<div class="container component vl-page-section" data-component-id="{{ componentId }}">
  <section class="py-5-nav">
    <header class="vl-page-head">
      <a href="{{ ('/blog') | shopUrl }}" class="vl-page-back">← Back to blog</a>
      <h1>{{ blogPost.title }}</h1>
      {% if blogPost.summary %}
      <p class="vl-page-sub">{{ blogPost.summary | safe }}</p>
      {% endif %}
    </header>
    <div class="row">
      <div class="col-lg-8 mx-auto">
        {% if blogPost.image_url %}
        <div class="vl-blog-featured mb-4">
          <img src="{{ blogPost.image_url }}" alt="{{ blogPost.title }}" class="img-fluid rounded">
        </div>
        {% endif %}
        <div class="editor vl-page-prose">
          {{ blogPost.content | safe }}
        </div>
        <p class="mt-4 pt-4 vl-blog-meta">
          <small>Published {{ blogPost.created_at | formatDate }}</small>
        </p>
      </div>
    </div>
  </section>
</div>
