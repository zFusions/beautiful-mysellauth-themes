<section class="container py-20 component" data-component-id="{{ componentId }}">
  <div class="text-center mb-5">
    {% if properties.heading %}<h2>{{ properties.heading | renderString }}</h2>{% endif %}
    {% if properties.subheading %}<p class="text-muted">{{ properties.subheading | renderString }}</p>{% endif %}
  </div>
  {% for row in properties.rows %}
    <div class="row g-4 mb-4">
      {% for review in row.reviews %}
        <div class="col-12 col-md-6 col-lg-4">
          <article class="card h-100 p-4">
            <div class="mb-3 text-warning">
              {% for star in range(review.rating or 0) %}<i class="fas fa-star"></i>{% endfor %}
            </div>
            <p>{{ review.text | renderString }}</p>
            <strong>{{ review.name | renderString }}</strong>
            {% if review.role %}<small class="text-muted">{{ review.role | renderString }}</small>{% endif %}
          </article>
        </div>
      {% endfor %}
    </div>
  {% endfor %}
</section>