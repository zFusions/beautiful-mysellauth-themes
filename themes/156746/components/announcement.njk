<div class="announcement-modern" style="{{ '' if global.components.announcement.text else 'display: none;' }}" data-component-id="announcement">
  <div class="announcement-container">
    <div class="announcement-content">
      <span class="announcement-dot"></span>
      <span class="announcement-text">{{ global.components.announcement.text | renderString }}</span>
      {% if global.components.announcement.link %}
      <a href="{{ global.components.announcement.link }}" class="announcement-link">
        {% if global.components.announcement.link_text %}
        {{ global.components.announcement.link_text | renderString }}
        {% else %}
        Learn more →
        {% endif %}
      </a>
      {% endif %}
    </div>
  </div>
</div>

<style>
.announcement-container {
  max-width: min(1100px, calc(94vw - 32px));
  margin: 0 auto;
  padding: 0 16px;
  display: flex;
  justify-content: center;
}

.announcement-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-size: 0.75rem;
  font-weight: 500;
}

.announcement-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
  animation: vl-announcement-pulse 2s ease-in-out infinite;
}

@keyframes vl-announcement-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.55; }
}

@media (max-width: 768px) {
  .announcement-content {
    font-size: 0.72rem;
    text-align: center;
    flex-wrap: wrap;
  }
}
</style>