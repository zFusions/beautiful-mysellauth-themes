{% if global.components.footer.show_shop_name or global.components.footer.show_logo or global.components.footer.show_socials or global.components.footer.links.length > 0 %}
<footer class="footer component nexus-footer" data-component-id="footer">
  <div class="vl-footer-light" aria-hidden="true">
    <span class="vl-footer-light__haze"></span>
    <span class="vl-footer-light__core"></span>
  </div>
  <div class="container">
    <div class="nexus-footer-content">
      <div class="footer-grid">
        <div class="footer-column brand">
          <div class="nexus-footer-brand">
            {% if global.components.footer.show_logo %}
            {% render_snippet "velora-brand-lockup.njk", size=34, class='vl-brand-lockup vl-brand-lockup--footer' %}
            {% else %}
            <span class="vl-brand-wordmark vl-brand-wordmark--footer vl-brand-wordmark--solo">{{ shop.name }}</span>
            {% endif %}
          </div>
          <p class="footer-brand-text">{{ global.components.footer.brand_text | default('Web store & Discord shop — scripts, software, licenses and premium products. Secure payments, instant delivery.') | renderString }}</p>
          <div class="footer-btns-group">
            {% if shop.discord_url %}
            <a href="{{ shop.discord_url }}" class="footer-social-btn discord" target="_blank">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.59 5.89c-1.23-.57-2.54-.99-3.92-1.23c-.17.3-.37.71-.5 1.04c-1.46-.22-2.91-.22-4.34 0c-.14-.33-.34-.74-.51-1.04c-1.38.24-2.69.66-3.92 1.23c-2.48 3.74-3.15 7.39-2.82 10.98c1.65 1.23 3.24 1.97 4.81 2.46c.39-.53.73-1.1 1.03-1.69c-.57-.21-1.11-.48-1.62-.79c.14-.1.27-.21.4-.31c3.13 1.46 6.52 1.46 9.61 0c.13.11.26.21.4.31c-.51.31-1.06.57-1.62.79c.3.59.64 1.16 1.03 1.69c1.57-.49 3.17-1.23 4.81-2.46c.39-4.17-.67-7.78-2.82-10.98Zm-9.75 8.78c-.94 0-1.71-.87-1.71-1.94s.75-1.94 1.71-1.94s1.72.87 1.71 1.94c0 1.06-.75 1.94-1.71 1.94Zm6.31 0c-.94 0-1.71-.87-1.71-1.94s.75-1.94 1.71-1.94s1.72.87 1.71 1.94c0 1.06-.75 1.94-1.71 1.94Z"/></svg>
              Join Discord
            </a>
            {% endif %}
            <a href="https://t.me/velorashp" class="footer-social-btn telegram" target="_blank">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 0 0-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.35-.01-1.02-.2-1.53-.37-.62-.2-1.12-.31-1.07-.65.02-.18.27-.36.75-.55 2.92-1.27 4.86-2.11 5.83-2.52 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z"/></svg>
              Join Telegram
            </a>
          </div>
        </div>

        <div class="footer-column">
          <h5 class="footer-column-title">Quick Links</h5>
          <div class="footer-links-list">
            {% for link in global.components.navbar.left_links %}
              <a href="{{ link.link | shopUrl }}" class="nexus-footer-link">{{ link.text }}</a>
            {% else %}
              <a href="{{ '/' | shopUrl }}" class="nexus-footer-link">Home</a>
            {% endfor %}
          </div>
        </div>

        <div class="footer-column">
          <h5 class="footer-column-title">Legal</h5>
          <div class="footer-links-list">
            <a href="{{ '/terms' | shopUrl }}" class="nexus-footer-link">Terms of Service</a>
            <a href="{{ '/privacy-policy' | shopUrl }}" class="nexus-footer-link">Privacy Policy</a>
            <a href="{{ '/refund-policy' | shopUrl }}" class="nexus-footer-link">Refund Policy</a>
          </div>
        </div>

        <div class="footer-column">
          <h5 class="footer-column-title">Support</h5>
          <div class="footer-links-list">
            <a href="{{ '/#faq' | shopUrl }}" class="nexus-footer-link">FAQ</a>
            <a href="{{ '/feedback' | shopUrl }}" class="nexus-footer-link">Reviews</a>
            <a href="{{ '/status' | shopUrl }}" class="nexus-footer-link">Status</a>
          </div>
        </div>
      </div>
    </div>

    <div class="nexus-footer-bottom">
      <div class="nexus-footer-copyright">
        <span>{{ global.components.footer.copyright_text }}</span>
      </div>
    </div>
  </div>
</footer>
{% endif %}