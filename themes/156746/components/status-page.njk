<div class="container component vl-page-section" data-component-id="{{ componentId }}">
  <section class="py-5-nav">
    {% render_snippet "vl-page-head.njk", properties=properties, fallbackTitle='Product Status' %}
    <div class="row">
      <div class="col-lg-10 mx-auto">
        <div class="status-cards vl-status-grid">
          {% for product in sortedItems %}
            {% if product.type == 'group' %}
              <div class="status-group">
                <h2>{{ product.name }}</h2>
                <div class="status-cards">
                  {% for product in product.products %}
                    {% render_snippet "status-card.njk", product=product %}
                  {% endfor %}
                </div>
              </div>
            {% elif not product.group_id %}
              {% render_snippet "status-card.njk", product=product %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </section>
</div>
