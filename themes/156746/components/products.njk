<section id="products" class="ps-section vl-section vl-products-section component" data-component-id="{{ componentId }}" data-scroll-section>
  <div class="container vl-products-container">
    <header class="vl-products-head" data-reveal>
      <h2 class="vl-products-title">{{ properties.title | renderString }}</h2>
      <p class="vl-products-sub">{{ properties.subtitle | default('Tap a product to open checkout.') | renderString }}</p>
    </header>

    <div class="vl-products-toolbar">
      <div id="categories" class="search-filter-wrapper" data-reveal>
        <div class="search-box-modern">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-icon" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          <input type="text" id="product-search" placeholder="Search products…" class="search-input-modern" aria-label="Search products">
        </div>
      </div>
    </div>

    <div id="no-products-message" class="vl-products-empty" style="display: none;">
      <div class="vl-products-empty-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </div>
      <h3 class="vl-products-empty-title">No matching products</h3>
      <p class="vl-products-empty-sub">Try a different keyword or browse the full catalog.</p>
      <button type="button" class="vl-products-empty-btn" onclick="document.getElementById('product-search').value = ''; document.getElementById('product-search').dispatchEvent(new Event('input'));">
        Clear search
      </button>
    </div>

    <div class="products-grid-wrap" id="products-grid" data-reveal-group>
      {% if (properties.ids | default([])) | length == 0 %}
        {% for product in sortedItems %}
          {% if product.type == 'group' or not product.group_id %}
            {% render_snippet "product-card.njk", product=product %}
          {% endif %}
        {% endfor %}
      {% else %}
        {% for product in helpers.components.products.getItemsByIds(sortedItems, properties.ids) %}
          {% render_snippet "product-card.njk", product=product %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('product-search');
  const productsGrid = document.getElementById('products-grid');
  const noProductsMessage = document.getElementById('no-products-message');
  const categoryTabs = document.querySelectorAll('.velora-tab');

  let activeCategory = null;

  function filterProducts() {
    const searchTerm = searchInput.value.toLowerCase().trim();
    const productCards = productsGrid.querySelectorAll('.product-card-container');
    let visibleCount = 0;

    productCards.forEach(card => {
      const productName = card.getAttribute('data-product-name').toLowerCase();
      const productCategory = card.getAttribute('data-product-category');

      const matchesSearch = productName.includes(searchTerm);
      const matchesCategory = !activeCategory || productCategory === activeCategory;

      if (matchesSearch && matchesCategory) {
        card.style.display = 'block';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    if (visibleCount === 0) {
      noProductsMessage.style.display = 'flex';
      productsGrid.style.display = 'none';
    } else {
      noProductsMessage.style.display = 'none';
      productsGrid.style.display = 'grid';
    }
  }

  if (searchInput) {
    searchInput.addEventListener('input', filterProducts);
  }

  categoryTabs.forEach(tab => {
    tab.addEventListener('click', function() {
      if (this.classList.contains('active')) {
        this.classList.remove('active');
        activeCategory = null;
      } else {
        categoryTabs.forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        activeCategory = this.textContent.trim();
      }
      filterProducts();
    });
  });

  if (!window.__vlProductMediaInit) {
    window.__vlProductMediaInit = true;

    function vlFitProductMedia(img) {
      var media = img.closest('.ps-product-media');
      if (!media || !img.naturalWidth || !img.naturalHeight) return;
      media.style.aspectRatio = img.naturalWidth + ' / ' + img.naturalHeight;
    }

    function vlInitProductMedia(root) {
      (root || document).querySelectorAll('.ps-product-img').forEach(function(img) {
        if (img.complete) vlFitProductMedia(img);
        else img.addEventListener('load', function() { vlFitProductMedia(img); }, { once: true });
      });
    }

    vlInitProductMedia(document);

    document.addEventListener('shown.bs.modal', function(e) {
      if (e.target && e.target.classList.contains('group-products-modal')) {
        vlInitProductMedia(e.target);
      }
    });
  }
});
</script>

{% for product in sortedItems %}
  {% if product.type == 'group' %}
    <div class="modal fade group-products-modal" id="group-modal-{{ product.id }}" tabindex="-1" aria-labelledby="group-modal-{{ product.id }}-label" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="group-modal-{{ product.id }}-label">
              {{ product.name }} Products
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="products row">
              {% for product in product.products %}
                {% render_snippet "product-card.njk", product=product %}
              {% endfor %}
            </div>
          </div>
        </div>
    </div>
  </div>
{% endif %}
{% endfor %}
