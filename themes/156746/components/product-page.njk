<div class="product-wrapper vl-pdp component" data-component-id="{{ componentId }}">
  {% set hasMedia = product.image_urls|length > 0 or product.image_url %}
  <section class="vl-pdp-section">
    <div class="vl-pdp-shell">
      {% if properties.show_back_link != false %}
      <a href="{{ properties.back_link | default('/#products') | shopUrl }}" class="vl-page-back vl-pdp-back" data-reveal>{{ properties.back_text | default('← Back to products') | renderString }}</a>
      {% endif %}
      <div class="vl-pdp-grid" data-reveal-group>
        <div class="vl-pdp-main" data-reveal x-data="{ accOpen: '{{ 'description' if not hasMedia else '' }}' }">
          <div class="vl-pdp-media">
            {% if product.image_urls|length > 0 %}
            <div class="vl-pdp-media-frame">
              <div class="carousel slide h-100" id="productImageCarousel" data-bs-ride="carousel">
                <div class="carousel-inner h-100">
                  {% for image in product.image_urls %}
                  <div class="carousel-item h-100 {{ 'active' if loop.first }}">
                    <img src="{{ image }}" alt="{{ product.name }}" class="vl-pdp-media-img" loading="eager" decoding="async"{% if loop.first %} fetchpriority="high"{% endif %} />
                  </div>
                  {% endfor %}
                </div>
              </div>
            </div>
            {% if product.image_urls|length > 1 %}
            <div class="vl-pdp-thumbs">
              {% for image in product.image_urls %}
              <button type="button" data-bs-target="#productImageCarousel" data-bs-slide-to="{{ loop.index0 }}" class="{{ 'active' if loop.first }}">
                <img src="{{ image }}" alt="{{ product.name }} thumbnail {{ loop.index }}" loading="lazy" decoding="async" />
              </button>
              {% endfor %}
            </div>
            {% endif %}
            {% elif product.image_url %}
            <div class="vl-pdp-media-frame">
              <img src="{{ product.image_url }}" class="vl-pdp-media-img" alt="{{ product.name }}" loading="eager" decoding="async" fetchpriority="high" />
            </div>
            {% else %}
            <div class="vl-pdp-banner" aria-hidden="false">
              <div class="vl-pdp-banner-inner">
                <p class="vl-pdp-banner-kicker">{{ properties.delivery_badge | default('Instant digital delivery') | renderString }}</p>
                <p class="vl-pdp-banner-title">{{ product.name }}</p>
              </div>
            </div>
            {% endif %}
          </div>

          <div class="vl-pdp-accordions">
            <div class="vl-pdp-acc-item">
              <button type="button" class="vl-pdp-acc-trigger" @click="accOpen = accOpen === 'description' ? '' : 'description'" :aria-expanded="accOpen === 'description'">
                <span>Product description</span>
                <svg class="vl-pdp-acc-chevron" :class="{ 'is-open': accOpen === 'description' }" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
              </button>
              <div class="vl-pdp-acc-panel" x-show="accOpen === 'description'" x-cloak>
                <div class="editor vl-pdp-acc-body">{{ product.description | safe }}</div>
              </div>
            </div>
            {% for productTab in product.product_tabs %}
            <div class="vl-pdp-acc-item">
              <button type="button" class="vl-pdp-acc-trigger" @click="accOpen = accOpen === '{{ productTab.slug }}' ? '' : '{{ productTab.slug }}'" :aria-expanded="accOpen === '{{ productTab.slug }}'">
                <span>{{ productTab.title }}</span>
                <svg class="vl-pdp-acc-chevron" :class="{ 'is-open': accOpen === '{{ productTab.slug }}' }" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
              </button>
              <div class="vl-pdp-acc-panel" x-show="accOpen === '{{ productTab.slug }}'" x-cloak>
                <div class="editor vl-pdp-acc-body">{{ productTab.content | safe }}</div>
              </div>
            </div>
            {% endfor %}
          </div>
        </div>

        <aside class="vl-pdp-rail" data-reveal x-data="productForm">
          <div class="vl-pdp-card vl-pdp-card--info">
            <div class="vl-pdp-info-head">
              <h1 class="vl-pdp-title">{{ product.name }}</h1>
              {% if product.product_badges.page|length > 0 %}
              {% set feat = product.product_badges.page[0] %}
              <span class="vl-pdp-featured-badge" style="--badge-color: {{ feat.color }}">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {{ feat.label }}
              </span>
              {% endif %}
            </div>

            <div class="vl-pdp-price-block">
              <div class="vl-pdp-price-top">
                <span class="vl-pdp-price" x-text="appCurrency.format(parseFloat(totalPrice), '{{ product.currency }}')"></span>
                <template x-if="showStrikethroughPrice">
                  <s class="vl-pdp-price-compare" x-text="appCurrency.format(strikethroughPrice, '{{ product.currency }}')"></s>
                </template>
              </div>
              <template x-if="showVolumeSave">
                <p class="vl-pdp-price-save">You save <span x-text="appCurrency.format(volumeSaveAmount, '{{ product.currency }}')"></span></p>
              </template>
            </div>

            <div class="vl-pdp-divider" aria-hidden="true"></div>

            <div class="vl-pdp-stock-wrap">
              <div class="vl-pdp-stock-head">
                <span class="vl-pdp-stock-label">Stock status</span>
                <span
                  class="vl-pdp-stock-count{% if product.visibility == 'on_hold' %} is-hold{% endif %}"
                  :class="{
                    'is-out': variant && variant.stock === 0 && '{{ product.visibility }}' !== 'on_hold'
                  }"
                >
                  {% if product.visibility == 'on_hold' %}
                  <span class="vl-pdp-stock-count-text">On hold</span>
                  {% else %}
                  <span class="vl-pdp-stock-count-inner" x-show="variant && variant.stock === -1">
                    <span class="vl-pdp-stock-count-text">In stock</span>
                  </span>
                  <span
                    class="vl-pdp-stock-count-inner"
                    x-show="variant && variant.stock > 0 && !product.hide_stock_count"
                  >
                    <span class="vl-pdp-stock-count-text" x-text="`${variant.stock} in stock`"></span>
                  </span>
                  <span class="vl-pdp-stock-count-inner" x-show="variant && variant.stock > 0 && product.hide_stock_count">
                    <span class="vl-pdp-stock-count-text">In stock</span>
                  </span>
                  <span class="vl-pdp-stock-count-inner" x-show="variant && variant.stock === 0" x-cloak>
                    <span class="vl-pdp-stock-count-text">Out of stock</span>
                  </span>
                  {% endif %}
                </span>
              </div>
              <div class="vl-pdp-stock-meter" aria-hidden="true">
                <div class="vl-pdp-stock-bar-track">
                  <div
                    class="vl-pdp-stock-bar-fill"
                    x-show="variant && variant.stock !== 0 && product.visibility != 'on_hold'"
                    :style="`width: ${stockBarPercent}%`"
                  ></div>
                </div>
              </div>
            </div>

            <div class="vl-pdp-trust-row">
              <span class="vl-pdp-trust">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
                {{ properties.trust_1 | default('Verified quality') | renderString }}
              </span>
              <span class="vl-pdp-trust">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                {{ properties.delivery_badge | default('Instant delivery') | renderString }}
              </span>
              <span class="vl-pdp-trust">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                {{ properties.trust_3 | default('24/7 support') | renderString }}
              </span>
            </div>

            {% render_snippet "vl-pdp-delivery-steps.njk" %}

            {% if product.status_color or product.status_text %}
            <div class="status vl-pdp-status" data-color="{{ product.status_color }}">
              <div class="indicator" style="background-color: {{ product.status_color }}"><div class="pulsating" style="background-color: {{ product.status_color }}"></div></div>
              <span class="label" style="color: {{ product.status_color }}">{{ product.status_text }}</span>
            </div>
            {% endif %}

            {% if 'sales' in liveStats or 'views' in liveStats %}
            <div class="vl-pdp-live-stats live-stats">
              {% if 'views' in liveStats %}
              <p><strong>{{ liveStats.views }}</strong> {{ 'person is' if liveStats.views == 1 else 'people are' }} viewing this</p>
              {% endif %}
              {% if 'sales' in liveStats %}
              {% set salesCountHoursLabelMap = { '1': 'hour', '6': '6 hours', '12': '12 hours', '24': '24 hours', '168': '7 days', '720': '30 days' } %}
              <p><strong>{{ liveStats.sales }}</strong> recent purchases{{ '.' if not product.sales_count_hours in salesCountHoursLabelMap else (' in the last ' ~ salesCountHoursLabelMap[product.sales_count_hours]) }}</p>
              {% endif %}
            </div>
            {% endif %}
          </div>

          <div class="vl-pdp-card vl-pdp-card--buy">
            {% render_snippet "product-form.njk", properties=properties, product=product, coupons=coupons %}
          </div>
        </aside>
      </div>

      {% if productUpsells.length > 0 %}
      <div class="vl-pdp-upsells">
        <div class="vl-pdp-upsells-head">
          <h2>{{ properties.upsells_title | default('Commonly bought together') | renderString }}</h2>
        </div>
        <div class="products-grid-wrap vl-pdp-upsells-grid">
          {% set ogProduct = product %}
          {% for upsell in productUpsells %}
            {% render_snippet "product-card.njk", product=upsell %}
          {% endfor %}
          {% set product = ogProduct %}
        </div>
      </div>
      {% endif %}
    </div>
  </section>
</div>

{% if 'latestOrders' in liveStats and liveStats.latestOrders|length > 0 %}
  <link href="https://cdn.jsdelivr.net/npm/flag-icons@7.3.2/css/flag-icons.min.css" rel="stylesheet" integrity="sha256-tyPeBlnZW2qWbAF1hQiCt9qo6SOgOSymvJBum+FrrwI=" crossorigin="anonymous">
  <div x-data="salesNotifications" x-cloak class="notification-container">
    <div x-show="show" class="notification-popup">
      <template x-if="order">
        <div class="notification-content">
          {% if product.image_urls|length > 0 %}
          <div class="notification-image-container">
            <img src="{{ product.image_urls[0] }}" alt="{{ product.name }} image" class="notification-image">
          </div>
          {% endif %}
          <div class="notification-text truncate">
            <p class="notification-text-primary text-muted">Someone purchased</p>
            <p class="notification-text-secondary">{{ product.name }}</p>
            <p class="notification-text-tertiary text-muted"><span x-text="getTimeAgo(order.completed_at)"></span></p>
          </div>
        </div>
      </template>
    </div>
  </div>
  <script>
    document.addEventListener('alpine:init', () => {
      Alpine.data('salesNotifications', () => ({
        displayTime: 8000, initTimeMin: 2000, initTimeMax: 4000, nextTimeMin: 8000, nextTimeMax: 12000,
        latestOrders: {{ liveStats.latestOrders | json }}, show: false,
        get order() { return this.latestOrders.length > 0 ? this.latestOrders[0] : null; },
        getRandomInterval(min, max) { return Math.floor(Math.random() * (max - min + 1)) + min; },
        getTimeAgo(input) {
          const date = (input instanceof Date) ? input : new Date(input);
          const formatter = new Intl.RelativeTimeFormat('en');
          const ranges = { years: 3600 * 24 * 365, months: 3600 * 24 * 30, weeks: 3600 * 24 * 7, days: 3600 * 24, hours: 3600, minutes: 60, seconds: 1 };
          const secondsElapsed = (date.getTime() - Date.now()) / 1000;
          for (let key in ranges) { if (ranges[key] < Math.abs(secondsElapsed)) return formatter.format(Math.round(secondsElapsed / ranges[key]), key); }
          return 'just now';
        },
        showNotification() {
          if (this.latestOrders.length === 0) return;
          this.show = true;
          setTimeout(() => { this.show = false; setTimeout(() => { this.latestOrders.shift(); if (this.latestOrders.length > 0) setTimeout(() => this.showNotification(), this.getRandomInterval(this.nextTimeMin, this.nextTimeMax)); }, 500); }, this.displayTime);
        },
        init() { setTimeout(() => this.showNotification(), this.getRandomInterval(this.initTimeMin, this.initTimeMax)); }
      }));
    });
  </script>
{% endif %}

{% if product.image_urls|length > 1 %}
<script>
  document.querySelectorAll('.vl-pdp-thumbs button').forEach((button) => {
    button.addEventListener('click', () => {
      button.parentNode.querySelectorAll('button').forEach((btn) => btn.classList.remove('active'));
      button.classList.add('active');
    });
  });
</script>
{% endif %}