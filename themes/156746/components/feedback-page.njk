<div class="container component vl-page-section" data-component-id="{{ componentId }}">
  <section class="py-5-nav">
    <div class="section-title">
      <h1>Feedback from users</h1>
    </div>
    <div class="testimonials row">
      {% for feedback in feedbacks %}
      <div class="col-12 col-md-6 col-lg-4 col-xl-3 mb-4">
        {% render_snippet "feedback-card.njk", feedback=feedback %}
      </div>
      {% endfor %}
    </div>
    {% if feedbacksPaginator and feedbacksPaginator.last_page > 1 %}
      {% render_snippet "pagination.njk", paginator=feedbacksPaginator %}
    {% endif %}
    <a href="{{ '/#products' | shopUrl }}" class="vl-page-cta">Browse products</a>
  </section>
</div>
