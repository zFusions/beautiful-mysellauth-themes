<section class="container py-20 vl-builder-section component" data-component-id="{{ componentId }}">
  <div class="vl-builder-card text-center p-5">
    {% if properties.title %}<h2>{{ properties.title | renderString }}</h2>{% endif %}
    {% if properties.text %}<p class="text-muted mt-3">{{ properties.text | renderString }}</p>{% endif %}
    {% if properties.button_link and properties.button_text %}
      <div class="mt-4">
        <a href="{{ properties.button_link | shopUrl }}" class="btn btn-primary">
          {% if properties.button_icon %}<i class="{{ properties.button_icon }}"></i>{% endif %}
          {{ properties.button_text | renderString }}
        </a>
      </div>
    {% endif %}
  </div>
</section>